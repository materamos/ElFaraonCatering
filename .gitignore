# Dependencies
node_modules/

# Build output
dist/
.astro/

# Vercel
.vercel/

# Supabase CLI
supabase/.temp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example
!.env.test

# TypeScript
*.tsbuildinfo

# User-uploaded content (no versionar fotos sueltas subidas en la raiz de uploads)
public/uploads/*.jpg
public/uploads/*.jpeg
public/uploads/*.png
public/uploads/*.gif
public/uploads/*.webp
public/uploads/*.avif
public/uploads/*.svg
!public/uploads/menu-placeholders/
!public/uploads/.gitkeep
# Fotos curadas del menu (build-time): SI se versionan (webp optimizados)
!public/uploads/menu/
!public/uploads/menu/**

# Branding (material de trabajo de diseno, no versionar)
docs/branding/

# Originales full de imagenes del menu (material fuente, no versionar; al repo solo van los webp optimizados)
assets/source-images/

# Editor settings
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Testing
coverage/
.nyc_output/
admin-auth-state.json

# Misc
*.local
.cache/
