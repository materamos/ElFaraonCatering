elativeFrom="margin"><wp14:pctWidth>0</wp14:pctWidth></wp14:sizeRelH><wp14:sizeRelV relativeFrom="margin"><wp14:pctHeight>0</wp14:pctHeight></wp14:sizeRelV></wp:anchor></w:drawing></w:r></w:p><w:p w14:paraId="54B578FF" w14:textId="4D7DFB6F" w:rsidR="00965A18" w:rsidRDefault="00965A18"/><w:p w14:paraId="1119381C" w14:textId="77777777" w:rsidR="00965A18" w:rsidRDefault="00965A18"/><w:p w14:paraId="0B21FD24" w14:textId="25EAC708" w:rsidR="00965A18" w:rsidRDefault="00965A18"><w:r><w:t>Guardar: guarda el dato nuevo, pero no lo muestra en el menú hasta que se publiquen los cambios. Cada cambio (que no sea de disponibilidad) se debe guardar.</w:t></w:r></w:p><w:p w14:paraId="77E1740A" w14:textId="065A1CAC" w:rsidR="00965A18" w:rsidRDefault="00965A18"><w:r><w:t xml:space="preserve">Publicar: </w:t></w:r><w:r w:rsidR="003D3D54"><w:t>c</w:t></w:r><w:r><w:t xml:space="preserve">arga toda la información nueva en los menús, </w:t></w:r><w:r w:rsidRPr="00DA7D61"><w:rPr><w:u w:val="single"/></w:rPr><w:t>tarda</w:t></w:r><w:r><w:t xml:space="preserve"> aproximadamente 60 segundos en ejecutarse la publicación. Lo recomendable es publicar una vez se hayan hecho todos los cambios (y guardado cada uno de estos). </w:t></w:r></w:p><w:p w14:paraId="4D107C91" w14:textId="28A4695B" w:rsidR="00965A18" w:rsidRDefault="00965A18"><w:r><w:t xml:space="preserve">Si se hace una publicación, pero </w:t></w:r><w:r w:rsidR="00DA7D61" w:rsidRPr="00DA7D61"><w:t xml:space="preserve">faltó </w:t></w:r><w:r><w:t xml:space="preserve">editar algo, luego de que finalice la publicación en curso se puede volver a hacer una nueva publicación. </w:t></w:r></w:p><w:p w14:paraId="434931BB" w14:textId="77777777" w:rsidR="003D3D54" w:rsidRDefault="003D3D54"/><w:p w14:paraId="761E20F8" w14:textId="1C2D08DB" w:rsidR="003D3D54" w:rsidRDefault="003D3D54" w:rsidP="003D3D54"><w:pPr><w:pStyle w:val="Ttulo2"/></w:pPr><w:r><w:t>Resumen</w:t></w:r></w:p><w:p w14:paraId="13031F29" w14:textId="6C009435" w:rsidR="003D3D54" w:rsidRDefault="003D3D54" w:rsidP="003D3D54"><w:pPr><w:pStyle w:val="Prrafodelista"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="003D3D54"><w:t>Disponibilidad: se aplica al instante.</w:t></w:r></w:p><w:p w14:paraId="2F3BA916" w14:textId="11F65249" w:rsidR="003D3D54" w:rsidRDefault="003D3D54" w:rsidP="003D3D54"><w:pPr><w:pStyle w:val="Prrafodelista"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="003D3D54"><w:t>Contenido/precios/servicio: guardar y luego publicar.</w:t></w:r></w:p><w:p w14:paraId="19DFCACF" w14:textId="6EDA3CA5" w:rsidR="003D3D54" w:rsidRPr="003D3D54" w:rsidRDefault="003D3D54" w:rsidP="003D3D54"><w:pPr><w:pStyle w:val="Prrafodelista"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="003D3D54"><w:t>Publicar sube todos los cambios guardados.</w:t></w:r></w:p><w:sectPr w:rsidR="003D3D54" w:rsidRPr="003D3D54"><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="1417" w:right="1701" w:bottom="1417" w:left="1701" w:header="708" w:footer="708" w:gutter="0"/><w:cols w:space="708"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>