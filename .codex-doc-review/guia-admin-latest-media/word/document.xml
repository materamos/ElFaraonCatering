fice/word/2020/wordml/sdtdatahash" xmlns:w16sdtfl="http://schemas.microsoft.com/office/word/2024/wordml/sdtformatlock" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh w16sdtfl w16du wp14"><w:body><w:p w14:paraId="56FC67F5" w14:textId="6483D487" w:rsidR="00D204E8" w:rsidRPr="00D204E8" w:rsidRDefault="00D204E8" w:rsidP="00DA7D61"><w:pPr><w:pStyle w:val="Ttulo2"/></w:pPr><w:r w:rsidRPr="00D204E8"><w:t>¿Para qué es el admin?</w:t></w:r></w:p><w:p w14:paraId="30020950" w14:textId="7783FE40" w:rsidR="00D204E8" w:rsidRDefault="00D204E8"><w:r w:rsidRPr="00D204E8"><w:t>La idea del admin es q</w:t></w:r><w:r><w:t xml:space="preserve">ue ustedes como Operadores puedan editar información del menú sin tener que meterse en el código de la página. </w:t></w:r><w:r w:rsidR="00DA7D61"><w:t>Está</w:t></w:r><w:r><w:t xml:space="preserve"> pensado para ajustarse a su flujo de trabajo, es decir, no se puede editar de punta a punta de forma </w:t></w:r><w:r w:rsidR="00DA7D61"><w:t>independiente,</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidR="00DA7D61" w:rsidRPr="00DA7D61"><w:t xml:space="preserve">sino </w:t></w:r><w:r><w:t>que hay reglas específicas, aplicadas a su negocio.</w:t></w:r></w:p><w:p w14:paraId="5D4F2FB6" w14:textId="77777777" w:rsidR="00D204E8" w:rsidRDefault="00D204E8"/><w:p w14:paraId="37603120" w14:textId="6847E1ED" w:rsidR="00D204E8" w:rsidRDefault="00D204E8" w:rsidP="00DA7D61"><w:pPr><w:pStyle w:val="Ttulo2"/></w:pPr><w:r><w:t>¿Cuáles son estas reglas?</w:t></w:r></w:p><w:p w14:paraId="0B4BD704" w14:textId="7784618F" w:rsidR="00D204E8" w:rsidRDefault="00D204E8"><w:r><w:t xml:space="preserve">Disponibilidad de ítems independiente por local. </w:t></w:r></w:p><w:p w14:paraId="7BE462B8" w14:textId="5A312663" w:rsidR="00D204E8" w:rsidRDefault="00D204E8"><w:r><w:t xml:space="preserve">Servicio </w:t></w:r><w:r w:rsidR="00DA7D61"><w:t>activo</w:t></w:r><w:r><w:t xml:space="preserve"> (Parrilla/menú del día) elegible por local. En caso de que compartan el </w:t></w:r><w:r w:rsidR="00DA7D61"><w:t>servicio activo</w:t></w:r><w:r><w:t xml:space="preserve">, las opciones se comparten. Si ambos tienen menú del día, </w:t></w:r><w:r w:rsidR="003D3D54"><w:t>e</w:t></w:r><w:r><w:t>l menú del día será el mismo en ambos locales.</w:t></w:r></w:p><w:p w14:paraId="35FE0840" w14:textId="6647BDB0" w:rsidR="00D204E8" w:rsidRDefault="00D204E8"><w:r><w:t xml:space="preserve">Menú fijo compartido. Los ítems compartidos por ambos menús comparten nombre/precio en ambos locales. El mismo ítem no puede tener precios diferentes en </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:t>corpo</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t>/</w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:t>teleinde</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t>.</w:t></w:r></w:p><w:p w14:paraId="14D645C9" w14:textId="77777777" w:rsidR="00D204E8" w:rsidRDefault="00D204E8"/><w:p w14:paraId="4ABF6F0C" w14:textId="77777777" w:rsidR="00965A18" w:rsidRDefault="00D204E8" w:rsidP="00DA7D61"><w:pPr><w:pStyle w:val="Ttulo2"/></w:pPr><w:r><w:t>Cambios instantáneos vs cambios que requieren publicación</w:t></w:r><w:r w:rsidR="00965A18"><w:t>:</w:t></w:r></w:p><w:p w14:paraId="4D233486" w14:textId="72CB1B32" w:rsidR="00965A18" w:rsidRDefault="00D204E8"><w:r><w:t>Hay 2 tipos de cambios que se pueden hacer desde el admi</w:t></w:r><w:r w:rsidR="00965A18"><w:t>n. C</w:t></w:r><w:r><w:t>uando se edita la dis</w:t></w:r><w:r w:rsidR="00965A18"><w:t xml:space="preserve">ponibilidad, el cambio aparece de forma instantánea en el menú. Cuando se modifica el </w:t></w:r><w:r w:rsidR="00DA7D61"><w:t xml:space="preserve">servicio activo </w:t></w:r><w:r w:rsidR="00965A18"><w:t>o un ítem del menú fijo compartido (nombre o precio), este cambio requiere guardar el dato nuevo y luego publicar.</w:t></w:r></w:p><w:p w14:paraId="43C8380C" w14:textId="35A0850D" w:rsidR="00965A18" w:rsidRDefault="00C45482"><w:r w:rsidRPr="00C45482"><w:rPr><w:noProof/></w:rPr><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="6A1D05CF" wp14:editId="7D4819D8"><wp:extent cx="5400040" cy="1810385"/><wp:effectExtent l="0" t="0" r="0" b="0"/><wp:docPr id="1344962121" name="Imagen 1"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="1344962121" name=""/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId5"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5400040" cy="1810385"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="55818745" w14:textId="1575F6C7" w:rsidR="00965A18" w:rsidRDefault="00C45482"><w:r><w:t>‘Volver a mostrar’ / ‘Ocultar ahora’ se aplican inmediatamente. No hay que guardar</w:t></w:r><w:r w:rsidR="003D3D54"><w:t xml:space="preserve"> ni </w:t></w:r><w:r><w:t>publicar estos cambios.</w:t></w:r></w:p><w:p w14:paraId="31BB3DC7" w14:textId="46F01E78" w:rsidR="00965A18" w:rsidRDefault="00965A18"><w:r w:rsidRPr="00DA7D61"><w:rPr><w:rStyle w:val="Ttulo2Car"/></w:rPr><w:lastRenderedPageBreak/><w:t>Guardar vs Publicar</w:t></w:r><w:r w:rsidR="00C45482" w:rsidRPr="00DA7D61"><w:rPr><w:rStyle w:val="Ttulo2Car"/></w:rPr><w:t>:</w:t></