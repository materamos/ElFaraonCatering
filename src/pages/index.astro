---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="El Faraón Catering"
  description="Catering y buffet diario con cocina casera para oficinas y estudios."
  bodyClass="landing-body"
>
  <main class="landing-page">
    <header class="landing-header" aria-label="Navegación principal" data-landing-header>
      <a class="landing-header__brand" href="/" aria-label="El Faraón Catering">
        <img
          src="/brand/el-faraon-logo-icon-orange-transparent.png"
          alt=""
          width="1800"
          height="1800"
        />
      </a>

      <nav class="landing-nav" aria-label="Secciones de la landing">
        <a href="#nosotros">Nosotros</a>
        <a href="#servicio">Servicio</a>
        <a class="landing-nav__button" href="#contacto">Contacto</a>
      </nav>
      <button
        class="landing-menu-toggle"
        type="button"
        aria-controls="landing-mobile-nav"
        aria-expanded="false"
        data-landing-menu-toggle
      >
        <span class="landing-menu-icon" aria-hidden="true"></span>
        <span class="landing-sr-only" data-landing-menu-label>Abrir menu</span>
      </button>
      <nav
        id="landing-mobile-nav"
        class="landing-mobile-nav"
        aria-label="Secciones de la landing"
        data-landing-mobile-nav
        hidden
      >
        <a href="#nosotros">Nosotros</a>
        <a href="#servicio">Servicio</a>
        <a href="#contacto">Contacto</a>
      </nav>
    </header>

    <section class="landing-hero" aria-labelledby="landing-title">
      <div class="landing-hero__overlay"></div>
      <div class="landing-hero__content">
        <img
          class="landing-hero__logo"
          src="/brand/el-faraon-logo.png"
          alt="El Faraón Catering"
          width="6170"
          height="1954"
          decoding="async"
        />
        <h1 id="landing-title">El Faraón Catering</h1>
      </div>
    </section>

    <section id="nosotros" class="landing-section landing-section--texture landing-section--about">
      <div class="landing-section__inner landing-about">
        <div class="landing-copy">
          <p class="landing-eyebrow">Sobre nosotros</p>
          <h2>Cocina casera, todos los días</h2>
          <p>
            Con años de trabajo, El Faraón construyó su reputación sobre la cercanía
            y la atención personalizada. Hoy, ese servicio de buffet funciona dentro
            de las oficinas y estudios de Telefe.
          </p>
        </div>

        <div class="landing-about__placeholder" aria-hidden="true"></div>
      </div>
    </section>

    <section id="servicio" class="landing-section landing-section--service">
      <div class="landing-section__inner">
        <div class="landing-copy landing-copy--compact">
          <p class="landing-eyebrow">Nuestro servicio</p>
          <h2>Lo que hacemos</h2>
        </div>

        <div class="landing-services" aria-label="Servicios de catering">
          <article class="landing-card">
            <div class="landing-card__placeholder" aria-hidden="true"></div>
            <div class="landing-card__body">
              <h3>Lorem ipsum</h3>
              <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer
                vitae mi at arcu posuere facilisis. Donec vitae risus sed urna
                laoreet dictum.
              </p>
            </div>
          </article>

          <article class="landing-card">
            <img
              class="landing-card__media"
              src="/landing/platos-telefe.webp"
              alt="Plato casero servido por El Faraón Catering"
              width="1085"
              height="1450"
              loading="lazy"
              decoding="async"
            />
            <div class="landing-card__body">
              <h3>Servicio de buffet</h3>
              <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer
                vitae mi at arcu posuere facilisis. Donec vitae risus sed urna
                laoreet dictum.
              </p>
            </div>
          </article>

          <article class="landing-card">
            <div class="landing-card__placeholder" aria-hidden="true"></div>
            <div class="landing-card__body">
              <h3>Lorem ipsum</h3>
              <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer
                vitae mi at arcu posuere facilisis. Donec vitae risus sed urna
                laoreet dictum.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="contacto" class="landing-section landing-section--texture landing-section--contact">
      <div class="landing-section__inner">
        <div class="landing-copy">
          <p class="landing-eyebrow">Contacto</p>
          <h2>Contactate con nosotros</h2>
          <address class="landing-contact__list">
            <a href="https://wa.me/5491160959892" target="_blank" rel="noopener noreferrer">
              <svg class="landing-contact__icon" aria-hidden="true" viewBox="0 0 24 24">
                <path
                  fill="#25d366"
                  d="M12 2.04a9.86 9.86 0 0 0-8.42 15l-1.18 4.3 4.4-1.15A9.85 9.85 0 1 0 12 2.04Z"
                />
                <path
                  fill="#fff"
                  d="M17.7 14.58c-.31-.16-1.85-.91-2.14-1.02-.29-.1-.5-.16-.71.16-.21.31-.81 1.02-.99 1.23-.18.21-.37.23-.68.08-.31-.16-1.32-.49-2.51-1.55a9.4 9.4 0 0 1-1.73-2.15c-.18-.31-.02-.48.14-.64.14-.14.31-.37.47-.55.16-.18.21-.31.31-.52.1-.21.05-.39-.03-.55-.08-.16-.71-1.7-.97-2.33-.26-.61-.52-.53-.71-.54h-.6c-.21 0-.55.08-.84.39-.29.31-1.1 1.07-1.1 2.62s1.13 3.05 1.29 3.26c.16.21 2.22 3.39 5.38 4.75.75.32 1.34.52 1.79.66.75.24 1.44.21 1.98.13.6-.09 1.85-.76 2.11-1.49.26-.73.26-1.36.18-1.49-.08-.13-.29-.21-.6-.37Z"
                />
              </svg>
              <span>+54 9 11 6095-9892</span>
            </a>
            <a href="https://wa.me/5491133454545" target="_blank" rel="noopener noreferrer">
              <svg class="landing-contact__icon" aria-hidden="true" viewBox="0 0 24 24">
                <path
                  fill="#25d366"
                  d="M12 2.04a9.86 9.86 0 0 0-8.42 15l-1.18 4.3 4.4-1.15A9.85 9.85 0 1 0 12 2.04Z"
                />
                <path
                  fill="#fff"
                  d="M17.7 14.58c-.31-.16-1.85-.91-2.14-1.02-.29-.1-.5-.16-.71.16-.21.31-.81 1.02-.99 1.23-.18.21-.37.23-.68.08-.31-.16-1.32-.49-2.51-1.55a9.4 9.4 0 0 1-1.73-2.15c-.18-.31-.02-.48.14-.64.14-.14.31-.37.47-.55.16-.18.21-.31.31-.52.1-.21.05-.39-.03-.55-.08-.16-.71-1.7-.97-2.33-.26-.61-.52-.53-.71-.54h-.6c-.21 0-.55.08-.84.39-.29.31-1.1 1.07-1.1 2.62s1.13 3.05 1.29 3.26c.16.21 2.22 3.39 5.38 4.75.75.32 1.34.52 1.79.66.75.24 1.44.21 1.98.13.6-.09 1.85-.76 2.11-1.49.26-.73.26-1.36.18-1.49-.08-.13-.29-.21-.6-.37Z"
                />
              </svg>
              <span>+54 9 11 3345-4545</span>
            </a>
            <a href="mailto:elfaraonbarnsmz@gmail.com">
              <svg class="landing-contact__icon" aria-hidden="true" viewBox="0 0 24 24">
                <path fill="#4285f4" d="M20.5 6.4v11.2h-3.2V11.3L12 15.28l-5.3-3.98v6.3H3.5V6.4h3.2L12 10.38l5.3-3.98h3.2Z" />
                <path fill="#34a853" d="M3.5 6.4v11.2h3.2V11.3L3.5 8.9V6.4Z" />
                <path fill="#fbbc04" d="M17.3 17.6h3.2V6.4l-3.2 2.5v8.7Z" />
                <path fill="#ea4335" d="M3.5 6.4 12 12.78 20.5 6.4v3.98L12 16.75 3.5 10.38V6.4Z" />
              </svg>
              <span>elfaraonbarnsmz@gmail.com</span>
            </a>
            <a
              href="https://www.instagram.com/elfaraoncatering/"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="landing-contact__icon" aria-hidden="true" viewBox="0 0 24 24">
                <defs>
                  <linearGradient id="landing-instagram-gradient" x1="3" x2="21" y1="21" y2="3">
                    <stop offset="0" stop-color="#feda75" />
                    <stop offset="0.28" stop-color="#fa7e1e" />
                    <stop offset="0.5" stop-color="#d62976" />
                    <stop offset="0.72" stop-color="#962fbf" />
                    <stop offset="1" stop-color="#4f5bd5" />
                  </linearGradient>
                </defs>
                <rect width="18" height="18" x="3" y="3" fill="url(#landing-instagram-gradient)" rx="5" />
                <circle cx="12" cy="12" r="4" fill="none" stroke="#fff" stroke-width="1.8" />
                <circle cx="17" cy="7" r="1.25" fill="#fff" />
              </svg>
              <span>@elfaraoncatering</span>
            </a>
          </address>
        </div>
      </div>
    </section>

    <footer class="landing-footer">
      <img
        src="/brand/el-faraon-logo.png"
        alt="El Faraón Catering"
        width="6170"
        height="1954"
        loading="lazy"
        decoding="async"
      />
    </footer>
  </main>

  <script is:inline src="/scripts/landing-menu.js" defer></script>
</BaseLayout>
