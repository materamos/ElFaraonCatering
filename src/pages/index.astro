---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="El Faraón Catering"
  description="Catering y buffet diario con cocina casera para oficinas y estudios."
  bodyClass="landing-body"
>
  <main class="landing-page">
    <header class="landing-header" aria-label="Navegación principal">
      <a class="landing-header__brand" href="/" aria-label="El Faraón Catering">
        <img
          src="/brand/el-faraon-logo-icon-orange-transparent.png"
          alt=""
          width="1800"
          height="1800"
        />
      </a>

      <nav class="landing-nav" aria-label="Secciones de la landing">
        <a href="#nosotros">Nosotros</a>
        <a href="#servicio">Servicio</a>
        <a class="landing-nav__button" href="#contacto">Contacto</a>
      </nav>
    </header>

    <section class="landing-hero" aria-labelledby="landing-title">
      <div class="landing-hero__overlay"></div>
      <div class="landing-hero__content">
        <img
          class="landing-hero__logo"
          src="/brand/el-faraon-logo.png"
          alt="El Faraón Catering"
          width="6170"
          height="1954"
          decoding="async"
        />
        <h1 id="landing-title">El Faraón Catering</h1>
      </div>
    </section>

    <section id="nosotros" class="landing-section landing-section--texture landing-section--about">
      <div class="landing-section__inner landing-about">
        <div class="landing-copy">
          <p class="landing-eyebrow">Sobre nosotros</p>
          <h2>Cocina casera, todos los días</h2>
          <p>
            Con años de trabajo, El Faraón construyó su reputación sobre la cercanía
            y la atención personalizada. Hoy, ese servicio de buffet funciona dentro
            de las oficinas y estudios de Telefe.
          </p>
        </div>

        <img
          class="landing-about__image"
          src="/landing/about-buffet.webp"
          alt="Plato casero servido por El Faraón Catering"
          width="1085"
          height="1450"
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>

    <section id="servicio" class="landing-section landing-section--service">
      <div class="landing-section__inner">
        <div class="landing-copy landing-copy--compact">
          <p class="landing-eyebrow">Nuestro servicio</p>
          <h2>Lo que servimos</h2>
        </div>

        <div class="landing-services" aria-label="Servicios de catering">
          <article class="landing-card">
            <div class="landing-card__placeholder" aria-hidden="true"></div>
            <div class="landing-card__body">
              <h3>Buffet diario</h3>
              <p>
                Con años de trabajo, El Faraón construyó su reputación sobre la
                cercanía y la atención personalizada. Hoy, ese servicio de buffet
                funciona dentro de las oficinas y estudios de Telefe.
              </p>
            </div>
          </article>

          <article class="landing-card">
            <div class="landing-card__placeholder" aria-hidden="true"></div>
            <div class="landing-card__body">
              <h3>Platos</h3>
              <p>
                Con años de trabajo, El Faraón construyó su reputación sobre la
                cercanía y la atención personalizada. Hoy, ese servicio de buffet
                funciona dentro de las oficinas y estudios de Telefe.
              </p>
            </div>
          </article>

          <article class="landing-card">
            <div class="landing-card__placeholder" aria-hidden="true"></div>
            <div class="landing-card__body">
              <h3>Bebidas</h3>
              <p>
                Con años de trabajo, El Faraón construyó su reputación sobre la
                cercanía y la atención personalizada. Hoy, ese servicio de buffet
                funciona dentro de las oficinas y estudios de Telefe.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section id="contacto" class="landing-section landing-section--texture landing-section--contact">
      <div class="landing-section__inner">
        <div class="landing-copy">
          <p class="landing-eyebrow">Contacto</p>
          <h2>Contactate con nosotros</h2>
          <address class="landing-contact__list">
            <a href="tel:+541122334455">11 2233 4455</a>
            <a href="mailto:elfaraoncatering@gmail.com">elfaraoncatering@gmail.com</a>
            <span>@elfaraoncatering</span>
          </address>
        </div>
      </div>
    </section>

    <footer class="landing-footer">
      <img
        src="/brand/el-faraon-logo.png"
        alt="El Faraón Catering"
        width="6170"
        height="1954"
        loading="lazy"
        decoding="async"
      />
    </footer>
  </main>
</BaseLayout>

<style>
  :global(body.landing-body) {
    background: #0f0e0d;
    color: #fffbf7;
    color-scheme: dark;
    font-family: "Inter", var(--font-body);
  }

  :global(body.landing-body) h1,
  :global(body.landing-body) h2,
  :global(body.landing-body) h3,
  :global(body.landing-body) p {
    margin: 0;
  }

  .landing-page {
    --landing-black: #0f0e0d;
    --landing-orange: #f57a0f;
    --landing-charcoal: #2a2622;
    --landing-bone: #fffbf7;
    --landing-gray: #8a8480;
    --landing-checker-a: #f8f8f8;
    --landing-checker-b: #e9e9e9;
    min-height: 100vh;
    overflow: hidden;
    background: var(--landing-black);
    color: var(--landing-bone);
  }

  .landing-header {
    display: flex;
    min-height: 4.9375rem;
    align-items: center;
    justify-content: space-between;
    gap: clamp(1.25rem, 5vw, 4.4375rem);
    box-sizing: border-box;
    padding: 1.375rem clamp(1rem, 6.25vw, 5.625rem);
    background: var(--landing-black);
  }

  .landing-header__brand {
    display: inline-grid;
    flex: 0 0 auto;
    width: 2.5rem;
    place-items: center;
  }

  .landing-header__brand:focus-visible,
  .landing-nav a:focus-visible,
  .landing-contact__list a:focus-visible {
    outline: 2px solid var(--landing-orange);
    outline-offset: 4px;
  }

  .landing-header__brand img,
  .landing-hero__logo,
  .landing-footer img {
    display: block;
    width: 100%;
    height: auto;
  }

  .landing-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(1rem, 5vw, 4.4375rem);
    margin-left: auto;
  }

  .landing-nav a {
    display: inline-flex;
    align-items: center;
    min-height: 1.0625rem;
    color: var(--landing-gray);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.0625rem;
    text-decoration: none;
    text-transform: uppercase;
  }

  .landing-nav .landing-nav__button {
    min-width: 6.625rem;
    min-height: 2.3125rem;
    justify-content: center;
    box-sizing: border-box;
    padding: 0.625rem 0.8125rem;
    color: var(--landing-black);
    font-weight: 600;
    background: var(--landing-orange);
    border-radius: 0.5rem;
  }

  .landing-hero {
    position: relative;
    display: grid;
    min-height: clamp(22rem, 37.222vw, 33.5rem);
    place-items: center;
    overflow: hidden;
    background-image: url("/landing/hero-salon.webp");
    background-position: center;
    background-size: cover;
  }

  .landing-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 62%);
  }

  .landing-hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    width: min(56.25rem, 82vw);
    justify-items: center;
  }

  .landing-hero h1 {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    white-space: nowrap;
    clip-path: inset(50%);
  }

  .landing-section {
    box-sizing: border-box;
    padding: clamp(3.5rem, 5.556vw, 5rem) clamp(1.25rem, 8.333vw, 7.5rem);
  }

  .landing-section--texture {
    background-color: #0b0b0a;
    background-image:
      linear-gradient(rgb(0 0 0 / 46%), rgb(0 0 0 / 46%)),
      url("/landing/brand-texture.webp");
    background-position: center;
    background-size: cover;
  }

  .landing-section--service {
    background: var(--landing-charcoal);
  }

  .landing-section__inner {
    width: min(100%, 75rem);
    margin-inline: auto;
  }

  .landing-about {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(17rem, 27.5rem);
    align-items: start;
    gap: clamp(2rem, 3.889vw, 3.5rem);
  }

  .landing-copy {
    display: grid;
    max-width: 44rem;
    gap: 0.875rem;
  }

  .landing-copy--compact {
    margin-bottom: 1.5rem;
  }

  .landing-eyebrow {
    color: var(--landing-gray);
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .landing-copy h2 {
    color: var(--landing-bone);
    font-family: "Fraunces", Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 2.361vw, 2.125rem);
    font-weight: 600;
    line-height: 1.4;
    text-wrap: balance;
  }

  .landing-copy p:not(.landing-eyebrow) {
    max-width: 33.9375rem;
    color: var(--landing-gray);
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1.6;
  }

  .landing-about__image {
    display: block;
    width: 100%;
    height: 18.75rem;
    object-fit: cover;
    object-position: center 56%;
    border: 1px solid var(--landing-charcoal);
  }

  .landing-services {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .landing-card {
    display: grid;
    grid-template-rows: 15rem minmax(0, 1fr);
    min-width: 0;
    overflow: hidden;
    background: var(--landing-bone);
    border: 1px solid var(--landing-charcoal);
  }

  .landing-card__placeholder {
    width: 100%;
    min-height: 15rem;
    background-color: var(--landing-checker-a);
    background-image:
      linear-gradient(45deg, var(--landing-checker-b) 25%, transparent 25%),
      linear-gradient(-45deg, var(--landing-checker-b) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, var(--landing-checker-b) 75%),
      linear-gradient(-45deg, transparent 75%, var(--landing-checker-b) 75%);
    background-position:
      0 0,
      0 1rem,
      1rem -1rem,
      -1rem 0;
    background-size: 2rem 2rem;
  }

  .landing-card__body {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    padding: 0.75rem 1.125rem 0.75rem;
  }

  .landing-card h3 {
    color: var(--landing-orange);
    font-family: "Fraunces", Georgia, "Times New Roman", serif;
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .landing-card p {
    color: var(--landing-charcoal);
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.6;
  }

  .landing-section--contact {
    display: grid;
    align-items: start;
  }

  .landing-contact__list {
    display: grid;
    gap: 0;
    color: var(--landing-gray);
    font-style: normal;
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 2.24;
  }

  .landing-contact__list a {
    width: fit-content;
    color: inherit;
    text-decoration: none;
  }

  .landing-footer {
    display: grid;
    min-height: 8.5rem;
    place-items: center;
    box-sizing: border-box;
    padding: 1.5rem 1.25rem;
    background: var(--landing-black);
  }

  .landing-footer img {
    width: min(58vw, 14.125rem);
  }

  @media (min-width: 960px) {
    .landing-header {
      height: 4.9375rem;
    }

    .landing-hero {
      height: 33.5rem;
      min-height: 33.5rem;
    }

    .landing-section--about {
      min-height: 31.0625rem;
    }

    .landing-about {
      grid-template-columns: minmax(0, 44rem) 27.5rem;
      height: 18.75rem;
    }

    .landing-section--service {
      min-height: 43.6875rem;
    }

    .landing-services {
      padding-top: 0.625rem;
    }

    .landing-card {
      min-height: 24.875rem;
    }

    .landing-section--contact {
      min-height: 24.625rem;
    }

    .landing-footer {
      height: 8.5rem;
    }
  }

  @media (max-width: 820px) {
    .landing-about,
    .landing-services {
      grid-template-columns: 1fr;
    }

    .landing-about__image {
      max-width: 34rem;
    }
  }

  @media (max-width: 520px) {
    .landing-header {
      min-height: auto;
      gap: 0.65rem;
      padding: 0.75rem;
    }

    .landing-header__brand {
      width: 2.15rem;
    }

    .landing-nav {
      gap: 0.45rem;
    }

    .landing-nav a {
      font-size: 0.63rem;
      line-height: 1;
    }

    .landing-nav .landing-nav__button {
      min-width: auto;
      min-height: 2.15rem;
      padding: 0.55rem 0.65rem;
    }

    .landing-hero {
      min-height: 19rem;
      background-position: center top;
    }

    .landing-hero__content {
      width: min(82vw, 24rem);
    }

    .landing-copy p:not(.landing-eyebrow),
    .landing-contact__list {
      font-size: 1rem;
    }
  }
</style>
