---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Menús | El Faraón Catering"
  description="Entrada general futura para los menús operativos de El Faraón Catering."
>
  <main class="page-shell">
    <section class="placeholder">
      <div class="placeholder__intro">
        <p class="eyebrow">Menús operativos</p>
        <h1 class="placeholder__title">Seleccion de menu</h1>
        <p class="body-copy">
          Esta ruta queda reservada como entrada general para los menús por ubicación de
          El Faraón Catering.
        </p>
      </div>

      <aside class="placeholder__panel">
        <p class="eyebrow">Estado actual</p>
        <div class="placeholder__content">
          <p>
            El menú Corpo está disponible en
            <a href="/menu/corpo/" class="text-link">
              /menu/corpo
            </a>.
          </p>
          <p>
            El menú Teleinde está disponible en
            <a href="/menu/teleinde/" class="text-link">
              /menu/teleinde
            </a>.
          </p>
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>
