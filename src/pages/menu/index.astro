---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MenuInfoPanel from "../../components/MenuInfoPanel.astro";
import MenuSection from "../../components/MenuSection.astro";

type MenuCollectionName = "daily-dishes" | "fixed-dishes" | "side-dishes" | "drinks";

interface MenuSectionDefinition {
  collection: MenuCollectionName;
  title: string;
  description: string;
}

interface SupportInfoRow {
  label: string;
  value: string;
}

const menuHeroContent = {
  eyebrow: "Menú operativo",
  title: "Menú digital del buffet",
  description:
    "Base funcional para la experiencia QR de El Faraon Catering dentro del edificio corporativo de Paramount+.",
};

const supportInfoRows: SupportInfoRow[] = [
  { label: "Horario", value: "8:00 a 20:00 h" },
  { label: "Medios de pago", value: "Efectivo / Mercado Pago" },
  { label: "Tarjetas", value: "Tarjeta de crédito / Tarjeta de débito" },
];

const menuSectionDefinitions: MenuSectionDefinition[] = [
  {
    collection: "daily-dishes",
    title: "Platos del día",
    description: "Opciones de rotación alta para la jornada actual del buffet.",
  },
  {
    collection: "fixed-dishes",
    title: "Platos fijos",
    description: "Base estable del menú para quienes buscan una elección conocida.",
  },
  {
    collection: "side-dishes",
    title: "Guarniciones",
    description: "Complementos disponibles para acompañar los platos principales.",
  },
  {
    collection: "drinks",
    title: "Bebidas",
    description: "Selección rápida de bebidas informativas y disponibilidad actual.",
  },
];

const sortItems = <T extends { data: { available: boolean; name: string } }>(items: T[]) =>
  [...items].sort((left, right) => {
    if (left.data.available !== right.data.available) {
      return left.data.available ? -1 : 1;
    }

    return left.data.name.localeCompare(right.data.name, "es");
  });

const collections = await Promise.all(
  menuSectionDefinitions.map((section) => getCollection(section.collection)),
);

const sections = menuSectionDefinitions.map((section, index) => ({
  title: section.title,
  description: section.description,
  items: sortItems(collections[index]),
}));
---

<BaseLayout
  title="Menú | El Faraon Catering"
  description="Menú operativo móvil de El Faraon Catering."
>
  <main class="page-shell space-y-6 sm:space-y-8">
    <section class="surface-card overflow-hidden">
      <div class="grid gap-6 p-5 sm:p-6 lg:grid-cols-[1.1fr_0.9fr] lg:p-8">
        <div class="space-y-4">
          <p class="eyebrow">{menuHeroContent.eyebrow}</p>
          <h1 class="max-w-xl text-5xl sm:text-6xl">{menuHeroContent.title}</h1>
          <p class="max-w-2xl text-base leading-7 text-[var(--color-muted)]">
            {menuHeroContent.description}
          </p>
        </div>

        <MenuInfoPanel title="Información útil" rows={supportInfoRows} />
      </div>
    </section>

    <div class="space-y-6 sm:space-y-8">
      {sections.map((section) => (
        <MenuSection
          title={section.title}
          description={section.description}
          items={section.items}
        />
      ))}
    </div>
  </main>
</BaseLayout>
