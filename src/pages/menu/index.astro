---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MenuInfoPanel from "../../components/MenuInfoPanel.astro";
import MenuSection from "../../components/MenuSection.astro";

type MenuSectionData = CollectionEntry<"menu-sections">["data"];

interface SupportInfoFact {
  label: string;
  value: string;
  link?: {
    text: string;
    href: string;
  };
}

interface SupportInfoPayment {
  label: string;
  methods: string[];
}

const menuHeroContent = {
  eyebrow: "Menú operativo",
  title: "Menú del buffet",
  description:
    "Opciones del día, platos, minutas, promociones y bebidas para la operación del buffet de El Faraon Catering dentro del edificio corporativo de Paramount+.",
};

const supportInfo = {
  facts: [
    { label: "Horario", value: "08:30 a 18:00 hs" },
    {
      label: "Contacto",
      value: "Contactanos por",
      link: {
        text: "WhatsApp",
        href: "https://wa.me/541133454545?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%3A%20",
      },
    },
    { label: "Disponibilidad", value: "Puede variar durante el día." },
  ] satisfies SupportInfoFact[],
  payment: {
    label: "Pagos",
    methods: ["Efectivo", "Mercado Pago", "Modo", "Tarjeta Crédito", "Tarjeta Débito"],
  } satisfies SupportInfoPayment,
};

const sectionEntries = await getCollection("menu-sections");
const sections: MenuSectionData[] = sectionEntries
  .map((section: CollectionEntry<"menu-sections">) => section.data)
  .sort((left: MenuSectionData, right: MenuSectionData) => left.order - right.order);
---

<BaseLayout
  title="Menú | El Faraon Catering"
  description="Menú operativo móvil de El Faraon Catering."
>
  <main class="page-shell space-y-6 sm:space-y-8">
    <section class="surface-card overflow-hidden">
      <div class="grid gap-6 p-5 sm:gap-8 sm:p-6 lg:grid-cols-[minmax(0,1.02fr)_minmax(19rem,0.98fr)] lg:items-center lg:p-8 xl:grid-cols-[minmax(0,1.08fr)_minmax(22rem,0.92fr)]">
        <div class="space-y-4 lg:space-y-5 lg:py-4">
          <p class="eyebrow">{menuHeroContent.eyebrow}</p>
          <h1 class="max-w-xl text-5xl sm:text-6xl xl:max-w-2xl">{menuHeroContent.title}</h1>
          <p class="max-w-2xl text-base leading-7 text-[var(--color-muted)] sm:text-lg sm:leading-8">
            {menuHeroContent.description}
          </p>
        </div>

        <MenuInfoPanel
          title="Información útil"
          facts={supportInfo.facts}
          payment={supportInfo.payment}
        />
      </div>
    </section>

    <div class="space-y-6 sm:space-y-8">
      {sections.map((section) => (
        <MenuSection
          title={section.title}
          description={section.description}
          note={section.note}
          items={section.items}
          groups={section.groups}
        />
      ))}
    </div>
  </main>

  <dialog class="photo-sheet" data-photo-sheet aria-labelledby="photo-sheet-title">
    <div class="photo-sheet__panel">
      <div class="photo-sheet__header">
        <p class="eyebrow">Foto</p>
        <button class="photo-sheet__close" type="button" data-photo-close>
          Cerrar
        </button>
      </div>

      <h2 class="photo-sheet__title" id="photo-sheet-title" data-photo-title>
        Foto del plato
      </h2>

      <div class="photo-frame">
        <img
          class="photo-frame__image"
          data-photo-image
          alt=""
          decoding="async"
          hidden
        />
        <p class="photo-sheet__error" data-photo-error hidden>No se pudo cargar la foto.</p>
      </div>
    </div>
  </dialog>
  <script is:inline src="/scripts/menu-photo-sheet.js" defer></script>
</BaseLayout>
