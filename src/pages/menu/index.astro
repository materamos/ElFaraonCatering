---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Menus | El Faraon Catering"
  description="Entrada general futura para los menus operativos de El Faraon Catering."
>
  <main class="page-shell">
    <section class="surface-card placeholder">
      <div class="placeholder__intro">
        <p class="eyebrow">Menus operativos</p>
        <h1 class="placeholder__title">Seleccion de menu</h1>
        <p class="body-copy">
          Esta ruta queda reservada como entrada general para los menus por ubicacion de
          El Faraon Catering.
        </p>
      </div>

      <aside class="placeholder__panel">
        <p class="eyebrow">Estado actual</p>
        <div class="placeholder__content">
          <p>
            El menu Corpo esta disponible en
            <a href="/menu/corpo/" class="text-link">
              /menu/corpo
            </a>.
          </p>
          <p>
            El menu Teleinde esta disponible en
            <a href="/menu/teleinde/" class="text-link">
              /menu/teleinde
            </a>.
          </p>
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>
