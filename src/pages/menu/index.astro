---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import MenuSection from "../../components/MenuSection.astro";

const sortItems = <T extends { data: { available: boolean; name: string } }>(items: T[]) =>
  [...items].sort((left, right) => {
    if (left.data.available !== right.data.available) {
      return left.data.available ? -1 : 1;
    }

    return left.data.name.localeCompare(right.data.name, "es");
  });

const [dailyDishes, fixedDishes, sideDishes, drinks] = await Promise.all([
  getCollection("daily-dishes"),
  getCollection("fixed-dishes"),
  getCollection("side-dishes"),
  getCollection("drinks"),
]);

const sections = [
  {
    title: "Platos del día",
    description: "Opciones de rotación alta para la jornada actual del buffet.",
    items: sortItems(dailyDishes),
  },
  {
    title: "Platos fijos",
    description: "Base estable del menú para quienes buscan una elección conocida.",
    items: sortItems(fixedDishes),
  },
  {
    title: "Guarniciones",
    description: "Complementos disponibles para acompañar los platos principales.",
    items: sortItems(sideDishes),
  },
  {
    title: "Bebidas",
    description: "Selección rápida de bebidas informativas y disponibilidad actual.",
    items: sortItems(drinks),
  },
];
---

<BaseLayout
  title="Menú | El Faraon Catering"
  description="Menú operativo móvil de El Faraon Catering."
>
  <main class="page-shell space-y-6 sm:space-y-8">
    <section class="surface-card overflow-hidden">
      <div class="grid gap-6 p-5 sm:p-6 lg:grid-cols-[1.1fr_0.9fr] lg:p-8">
        <div class="space-y-4">
          <p class="eyebrow">Menú operativo</p>
          <h1 class="max-w-xl text-5xl sm:text-6xl">Menú digital del buffet</h1>
          <p class="max-w-2xl text-base leading-7 text-[var(--color-muted)]">
            Base funcional para la experiencia QR de El Faraon Catering dentro del edificio corporativo
            de Paramount+. El contenido todavía es de ejemplo, pero la estructura ya quedó lista para crecer.
          </p>
        </div>

        <div class="rounded-[var(--radius-panel)] bg-[var(--color-surface-strong)] p-5">
          <p class="eyebrow">Estado del sistema</p>
          <dl class="mt-4 grid gap-3 text-sm">
            <div class="flex items-center justify-between gap-4 border-b border-[var(--color-line)] pb-3">
              <dt class="text-[var(--color-muted)]">Render</dt>
              <dd class="font-semibold text-[var(--color-ink)]">Estático</dd>
            </div>
            <div class="flex items-center justify-between gap-4 border-b border-[var(--color-line)] pb-3">
              <dt class="text-[var(--color-muted)]">Contenido</dt>
              <dd class="font-semibold text-[var(--color-ink)]">YAML tipado</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-[var(--color-muted)]">CMS</dt>
              <dd class="font-semibold text-[var(--color-ink)]">Pendiente</dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

    <div class="space-y-6 sm:space-y-8">
      {sections.map((section) => (
        <MenuSection
          title={section.title}
          description={section.description}
          items={section.items}
        />
      ))}
    </div>
  </main>
</BaseLayout>
