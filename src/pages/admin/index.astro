---
import "../../admin/styles.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadSupabaseMenuPublicationContentHash } from "../../utils/menuSupabaseContent";

const deployedContentHash = await loadSupabaseMenuPublicationContentHash();
---

<BaseLayout
  title="Admin operativo | El Faraón Catering"
  description="Panel operativo para preparar menú del día, parrilla, disponibilidad, precios y publicación."
>
  <main
    class="admin-root"
    data-admin-root
    data-deployed-content-hash={deployedContentHash}
  >
    <section class="admin-loading" aria-live="polite" aria-busy="true">
      <div class="admin-loading__panel">
        <div class="admin-loading__indicator" aria-hidden="true"></div>
        <div class="admin-loading__content">
          <p class="admin-kicker">Panel operativo</p>
          <h1 class="admin-title">Cargando panel operativo</h1>
          <p class="admin-muted">Estamos verificando tu sesion y permisos.</p>
          <p class="admin-loading__help">Si tarda mas de unos segundos, recarga la pagina o volve a iniciar sesion.</p>
        </div>
      </div>
    </section>
  </main>

  <script>
    import "../../admin/main";
  </script>
</BaseLayout>
