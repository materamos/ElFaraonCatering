---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Administración | El Faraon Catering"
  description="Ruta reservada para la futura integración con Decap CMS."
>
  <main class="page-shell">
    <section class="surface-card max-w-3xl p-6 sm:p-8">
      <p class="eyebrow">Ruta reservada</p>
      <h1 class="mt-3 text-4xl">Administración del contenido</h1>
      <p class="mt-4 text-base leading-7 text-[var(--color-muted)]">
        Esta pantalla queda apartada para la futura integración con Decap CMS. En este hito no hay
        autenticación ni edición web todavía: primero dejamos estable la estructura del sitio y del contenido.
      </p>
    </section>
  </main>
</BaseLayout>
