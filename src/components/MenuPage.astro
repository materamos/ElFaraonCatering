---
import type { MenuProfileData, MenuSectionData } from "../types/menu";
import BaseLayout from "../layouts/BaseLayout.astro";
import MenuSection from "./MenuSection.astro";

interface Props {
  menuId: string;
  profile: MenuProfileData;
  sections: MenuSectionData[];
}

const { menuId, profile, sections } = Astro.props;
const publicSupabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const publicSupabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const scheduleFact = profile.facts.find((fact) => fact.id === "horario");
const paymentFact = profile.facts.find((fact) => fact.id === "pagos");
const contactFact = profile.facts.find((fact) => fact.id === "contacto" && fact.link);
const paymentMethods = paymentFact?.value
  .split(",")
  .map((method) => method.trim())
  .filter(Boolean);
const paymentMethodRows =
  paymentMethods && paymentMethods.length > 3
    ? [paymentMethods.slice(0, 2), paymentMethods.slice(2)]
    : [paymentMethods ?? []];
const getSectionNavLabel = (section: MenuSectionData) =>
  section.sectionId === "platos-principales"
    ? "Principales"
    : section.sectionId === "promociones"
      ? "Promos cafetería"
      : section.title;
---

<BaseLayout
  title={`${profile.title} | El Faraón Catering`}
  description={profile.title}
  bodyClass="menu-body"
>
  <main
    id="menu-top"
    class="page-shell menu-page"
    data-menu-id={menuId}
    data-supabase-url={publicSupabaseUrl}
    data-supabase-anon-key={publicSupabaseAnonKey}
  >
    <header class="menu-page__hero">
      <div class="menu-page__hero-top">
        <h1 class="menu-page__hero-label">{profile.title}</h1>
        <p class="menu-page__hero-label">buffet</p>
      </div>

      <div class="menu-page__logo-space">
        <img
          class="menu-page__logo"
          src="/brand/el-faraon-logo.png"
          alt="El Faraon Catering"
        />
      </div>

    </header>

    {(scheduleFact || paymentFact) && (
      <section class="menu-page__info-bar" aria-label="Horario y medios de pago">
        {scheduleFact && (
          <div class="menu-page__info-col">
            <svg
              class="menu-page__info-icon"
              viewBox="0 0 22 22"
              fill="none"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M11 19.25C15.5563 19.25 19.25 15.5563 19.25 11C19.25 6.44365 15.5563 2.75 11 2.75C6.44365 2.75 2.75 6.44365 2.75 11C2.75 15.5563 6.44365 19.25 11 19.25Z"
                stroke="currentColor"
                stroke-width="1.375"
              />
              <path
                d="M11 6.875V11L13.75 12.65"
                stroke="currentColor"
                stroke-width="1.375"
                stroke-linecap="round"
              />
            </svg>
            <div class="menu-page__info-text">
              <p class="menu-page__info-title">Lunes a Viernes</p>
              <p class="menu-page__info-detail">{scheduleFact.value}</p>
            </div>
          </div>
        )}

        {paymentFact && (
          <div class="menu-page__info-col">
            <svg
              class="menu-page__info-icon"
              viewBox="0 0 22 22"
              fill="none"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M17.4167 5.5H4.58333C3.57081 5.5 2.75 6.32081 2.75 7.33333V14.6667C2.75 15.6792 3.57081 16.5 4.58333 16.5H17.4167C18.4292 16.5 19.25 15.6792 19.25 14.6667V7.33333C19.25 6.32081 18.4292 5.5 17.4167 5.5Z"
                stroke="currentColor"
                stroke-width="1.375"
              />
              <path
                d="M2.75 9.16663H19.25"
                stroke="currentColor"
                stroke-width="1.375"
              />
            </svg>
            <div class="menu-page__info-text">
              <div class="menu-page__info-detail menu-page__payment-methods">
                {paymentMethodRows.map((row) => (
                  <span class="menu-page__payment-method-row">{row.join(" · ")}</span>
                ))}
              </div>
            </div>
          </div>
        )}
      </section>
    )}

    <span class="menu-index-sentinel" data-menu-index-sentinel aria-hidden="true"></span>
    <nav class="menu-index" aria-labelledby="menu-index-title">
      <a class="menu-index__brand" href="#menu-top" aria-label="Volver al inicio del menu">
        <img
          class="menu-index__brand-image"
          src="/brand/el-faraon-logo.png"
          width="6170"
          height="1954"
          alt=""
          aria-hidden="true"
        />
      </a>
      <h2 class="menu-index__title" id="menu-index-title">Secciones</h2>
      <ul class="menu-index__list">
        {sections.map((section) => (
          <li class="menu-index__item">
            <a class="menu-index__link" href={`#${section.sectionId}`}>
              {getSectionNavLabel(section)}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="menu-page__sections">
      {sections.map((section) => (
        <MenuSection
          menuId={menuId}
          sectionId={section.sectionId}
          title={section.title}
          presentation={section.presentation}
          items={section.items}
        />
      ))}
    </div>

    {contactFact?.link && (
      <a
        class="menu-whatsapp-button"
        href={contactFact.link.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Contactar por ${contactFact.link.text}`}
      >
        <svg
          class="menu-whatsapp-button__icon"
          viewBox="0 0 32 32"
          aria-hidden="true"
          focusable="false"
        >
          <path
            fill="currentColor"
            d="M16.02 3.2a12.73 12.73 0 0 0-10.9 19.27L3.6 28.8l6.45-1.49A12.8 12.8 0 1 0 16.02 3.2Zm0 2.32a10.48 10.48 0 0 1 8.86 16.07 10.52 10.52 0 0 1-13.97 3.5l-.39-.23-3.76.87.89-3.64-.25-.4A10.42 10.42 0 0 1 16.02 5.52Zm-4.5 4.98c-.23 0-.59.08-.9.42-.31.34-1.18 1.16-1.18 2.82 0 1.66 1.21 3.27 1.38 3.49.17.23 2.34 3.75 5.78 5.1 2.86 1.13 3.44.9 4.06.85.62-.06 2.01-.82 2.29-1.61.28-.79.28-1.47.2-1.61-.08-.14-.31-.23-.65-.4-.34-.17-2.01-.99-2.32-1.1-.31-.12-.54-.17-.76.17-.23.34-.87 1.1-1.07 1.33-.2.23-.39.25-.73.08-.34-.17-1.42-.52-2.71-1.67-1-.89-1.68-2-1.88-2.34-.2-.34-.02-.52.15-.69.16-.15.34-.39.51-.59.17-.2.23-.34.34-.56.11-.23.06-.42-.03-.59-.08-.17-.76-1.84-1.04-2.51-.27-.65-.55-.56-.76-.57h-.68Z"
          />
        </svg>
      </a>
    )}
  </main>

  <dialog class="photo-sheet" data-photo-sheet aria-labelledby="photo-sheet-title">
    <div class="photo-sheet__panel">
      <div class="photo-sheet__header">
        <h2 class="photo-sheet__title" id="photo-sheet-title" data-photo-title>
          Foto del plato
        </h2>
        <button class="photo-sheet__close" type="button" data-photo-close>
          Cerrar
        </button>
      </div>

      <div class="photo-frame" data-photo-frame></div>
      <div class="photo-sheet__controls" data-photo-controls hidden>
        <button class="photo-sheet__nav" type="button" data-photo-prev>
          Anterior
        </button>
        <span class="photo-sheet__count" data-photo-count></span>
        <button class="photo-sheet__nav" type="button" data-photo-next>
          Siguiente
        </button>
      </div>
    </div>
  </dialog>
  <script is:inline type="module" src="/scripts/menu-index-sticky.js"></script>
  <script is:inline type="module" src="/scripts/menu-photo-sheet.js"></script>
  <script is:inline type="module" src="/scripts/menu-availability-overlay.js"></script>
</BaseLayout>
