---
import type { MenuProfileData, MenuSectionData } from "../types/menu";
import BaseLayout from "../layouts/BaseLayout.astro";
import MenuInfoPanel from "./MenuInfoPanel.astro";
import MenuSection from "./MenuSection.astro";

interface Props {
  menuId: string;
  profile: MenuProfileData;
  sections: MenuSectionData[];
}

const { menuId, profile, sections } = Astro.props;
---

<BaseLayout
  title={`${profile.title} | El Faraon Catering`}
  description={profile.description}
>
  <main class="page-shell menu-page" data-menu-id={menuId}>
    <section class="menu-page__hero">
      <div class="menu-page__intro">
        <p class="eyebrow">{profile.eyebrow}</p>
        <h1 class="menu-page__title">{profile.title}</h1>
        <p class="body-copy menu-page__description">
          {profile.description}
        </p>
      </div>

      <MenuInfoPanel
        title={profile.infoTitle}
        facts={profile.facts}
        payment={profile.payment}
      />
    </section>

    <div class="menu-page__sections">
      {sections.map((section) => (
        <MenuSection
          menuId={menuId}
          sectionId={section.sectionId}
          title={section.title}
          description={section.description}
          note={section.note}
          presentation={section.presentation}
          items={section.items}
          groups={section.groups}
        />
      ))}
    </div>
  </main>

  <dialog class="photo-sheet" data-photo-sheet aria-labelledby="photo-sheet-title">
    <div class="photo-sheet__panel">
      <div class="photo-sheet__header">
        <p class="eyebrow">Foto</p>
        <button class="photo-sheet__close" type="button" data-photo-close>
          Cerrar
        </button>
      </div>

      <h2 class="photo-sheet__title" id="photo-sheet-title" data-photo-title>
        Foto del plato
      </h2>

      <div class="photo-frame">
        <img
          class="photo-frame__image"
          data-photo-image
          alt=""
          decoding="async"
          hidden
        />
        <p class="photo-sheet__error" data-photo-error hidden>No se pudo cargar la foto.</p>
      </div>
    </div>
  </dialog>
  <script is:inline type="module" src="/scripts/menu-photo-sheet.js"></script>
  <script>
    import "../scripts/menuAvailabilityOverlay";
  </script>
</BaseLayout>
