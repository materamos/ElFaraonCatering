---
import type { MenuProfileData, MenuSectionData } from "../types/menu";
import BaseLayout from "../layouts/BaseLayout.astro";
import MenuSection from "./MenuSection.astro";

interface Props {
  menuId: string;
  profile: MenuProfileData;
  sections: MenuSectionData[];
}

const { menuId, profile, sections } = Astro.props;
const publicSupabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const publicSupabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const scheduleFact = profile.facts.find((fact) => fact.id === "horario");
const paymentFact = profile.facts.find((fact) => fact.id === "pagos");
const contactFact = profile.facts.find((fact) => fact.id === "contacto" && fact.link);
const paymentMethods = paymentFact?.value
  .split("•")
  .map((method) => method.trim())
  .filter(Boolean);
const getSectionNavLabel = (section: MenuSectionData) =>
  section.sectionId === "platos-principales"
    ? "Principales"
    : section.sectionId === "tartas-tortillas-omelettes"
      ? "Tartas"
    : section.sectionId === "promociones"
      ? "Promos cafetería"
      : section.title;
---

<BaseLayout
  title={`${profile.title} | El Faraón Catering`}
  description={profile.title}
  bodyClass="menu-body"
>
  <main
    id="menu-top"
    class="page-shell menu-page"
    data-menu-id={menuId}
    data-supabase-url={publicSupabaseUrl}
    data-supabase-anon-key={publicSupabaseAnonKey}
  >
    <header class="menu-page__hero">
      <div class="menu-page__hero-top">
        <h1 class="menu-page__hero-label">{profile.title}</h1>
        <p class="menu-page__hero-label">buffet</p>
      </div>

      <div class="menu-page__logo-space">
        <img
          class="menu-page__logo"
          src="/brand/el-faraon-logo.png"
          alt="El Faraon Catering"
        />
      </div>

    </header>

    {(scheduleFact || paymentFact) && (
      <section class="menu-page__service-card" aria-label="Horario y medios de pago">
        {scheduleFact && (
          <div class="menu-page__service-panel menu-page__service-panel--schedule">
            <svg
              class="menu-page__service-icon menu-page__service-icon--time"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                fill="currentColor"
                d="M12.9474 11.6163V6.63158C12.9474 6.36316 12.8565 6.13811 12.6748 5.95642C12.4932 5.77495 12.2681 5.68421 11.9997 5.68421C11.7311 5.68421 11.5061 5.77495 11.3248 5.95642C11.1434 6.13811 11.0526 6.36316 11.0526 6.63158V11.9078C11.0526 12.0564 11.0802 12.2004 11.1354 12.3398C11.1903 12.4792 11.2769 12.608 11.3953 12.7263L15.7216 17.0526C15.8963 17.2276 16.1161 17.3171 16.3809 17.3211C16.6458 17.3251 16.8697 17.2356 17.0526 17.0526C17.2356 16.8697 17.3271 16.6478 17.3271 16.3869C17.3271 16.1263 17.2356 15.9045 17.0526 15.7216L12.9474 11.6163ZM12.0022 24C10.3424 24 8.78232 23.6851 7.32189 23.0552C5.86147 22.4253 4.59116 21.5704 3.51095 20.4906C2.43074 19.4108 1.57547 18.1411 0.945158 16.6813C0.315052 15.2215 0 13.6618 0 12.0022C0 10.3424 0.314947 8.78232 0.944842 7.32189C1.57474 5.86147 2.42958 4.59116 3.50937 3.51095C4.58916 2.43074 5.85895 1.57547 7.31874 0.945158C8.77853 0.315052 10.3382 0 11.9978 0C13.6576 0 15.2177 0.314947 16.6781 0.944842C18.1385 1.57474 19.4088 2.42958 20.4891 3.50937C21.5693 4.58916 22.4245 5.85895 23.0548 7.31874C23.6849 8.77853 24 10.3382 24 11.9978C24 13.6576 23.6851 15.2177 23.0552 16.6781C22.4253 18.1385 21.5704 19.4088 20.4906 20.4891C19.4108 21.5693 18.1411 22.4245 16.6813 23.0548C15.2215 23.6849 13.6618 24 12.0022 24ZM12 22.1053C14.8 22.1053 17.1842 21.1211 19.1526 19.1526C21.1211 17.1842 22.1053 14.8 22.1053 12C22.1053 9.2 21.1211 6.81579 19.1526 4.84737C17.1842 2.87895 14.8 1.89474 12 1.89474C9.2 1.89474 6.81579 2.87895 4.84737 4.84737C2.87895 6.81579 1.89474 9.2 1.89474 12C1.89474 14.8 2.87895 17.1842 4.84737 19.1526C6.81579 21.1211 9.2 22.1053 12 22.1053Z"
              />
            </svg>
            <span class="menu-page__service-label">LUN A VIER</span>
            <span class="menu-page__service-value">{scheduleFact.value}</span>
          </div>
        )}

        {paymentFact && (
          <div class="menu-page__service-panel menu-page__service-panel--payments">
            <svg
              class="menu-page__service-icon menu-page__service-icon--payment"
              viewBox="0 0 24 17"
              aria-hidden="true"
              focusable="false"
            >
              <path
                fill="currentColor"
                d="M14.0682 9.36766C13.2425 9.36766 12.5436 9.08765 11.9716 8.52763C11.3996 7.9676 11.1136 7.28339 11.1136 6.47498C11.1136 5.66657 11.3996 4.98235 11.9716 4.42233C12.5436 3.86231 13.2425 3.5823 14.0682 3.5823C14.8939 3.5823 15.5928 3.86231 16.1648 4.42233C16.7368 4.98235 17.0228 5.66657 17.0228 6.47498C17.0228 7.28339 16.7368 7.9676 16.1648 8.52763C15.5928 9.08765 14.8939 9.36766 14.0682 9.36766ZM6.27256 12.9502C5.68519 12.9502 5.18232 12.7454 4.76395 12.3358C4.34559 11.9262 4.1364 11.4338 4.1364 10.8585V2.09141C4.1364 1.51634 4.34559 1.02401 4.76395 0.614405C5.18232 0.204802 5.68519 0 6.27256 0H21.8635C22.4511 0 22.9541 0.204802 23.3724 0.614405C23.7908 1.02401 24 1.51634 24 2.09141V10.8585C24 11.4338 23.7908 11.9262 23.3724 12.3358C22.9541 12.7454 22.4511 12.9502 21.8635 12.9502H6.27256ZM8.0453 11.2146H20.0911C20.0911 10.6376 20.3003 10.1447 20.7187 9.7359C21.137 9.32726 21.6399 9.12294 22.2273 9.12294V3.82702C21.6379 3.82702 21.1346 3.62222 20.7172 3.21261C20.2998 2.80301 20.0911 2.31067 20.0911 1.73561H8.0453C8.0453 2.3126 7.83612 2.80542 7.41775 3.21406C6.99938 3.6227 6.49652 3.82702 5.90915 3.82702V9.12294C6.49849 9.12294 7.00185 9.32774 7.41923 9.73734C7.83661 10.1469 8.0453 10.6394 8.0453 11.2146ZM19.5909 17H2.13645C1.54889 17 1.04592 16.7952 0.627551 16.3856C0.209184 15.976 0 15.4836 0 14.9083V4.31675C0 4.07087 0.0849934 3.86472 0.25498 3.69829C0.424966 3.53206 0.635529 3.44894 0.886667 3.44894C1.138 3.44894 1.34847 3.53206 1.51806 3.69829C1.68785 3.86472 1.77274 4.07087 1.77274 4.31675V14.9083C1.77274 14.9972 1.81056 15.0788 1.8862 15.153C1.96203 15.2273 2.04545 15.2644 2.13645 15.2644H19.5909C19.842 15.2644 20.0526 15.3476 20.2226 15.514C20.3924 15.6803 20.4773 15.8864 20.4773 16.1325C20.4773 16.3786 20.3924 16.5846 20.2226 16.7507C20.0526 16.9169 19.842 17 19.5909 17ZM6.27256 11.2146H5.90915V1.73561H6.27256C6.17407 1.73561 6.08888 1.7708 6.01699 1.84119C5.94509 1.91158 5.90915 1.99499 5.90915 2.09141V10.8585C5.90915 10.955 5.94509 11.0384 6.01699 11.1088C6.08888 11.1793 6.17407 11.2146 6.27256 11.2146Z"
              />
            </svg>
            <div class="menu-page__payment-methods" aria-label="Medios de pago">
              {(paymentMethods ?? [paymentFact.value]).map((method) => (
                <span class="menu-page__payment-method">{method}</span>
              ))}
            </div>
          </div>
        )}
      </section>
    )}

    <span class="menu-index-sentinel" data-menu-index-sentinel aria-hidden="true"></span>
    <nav class="menu-index" aria-labelledby="menu-index-title">
      <a class="menu-index__brand" href="#menu-top" aria-label="Volver al inicio del menu">
        <img
          class="menu-index__brand-image"
          src="/brand/el-faraon-logo.png"
          width="6170"
          height="1954"
          alt=""
          aria-hidden="true"
        />
      </a>
      <h2 class="menu-index__title" id="menu-index-title">Secciones</h2>
      <ul class="menu-index__list">
        {sections.map((section) => (
          <li class="menu-index__item">
            <a class="menu-index__link" href={`#${section.sectionId}`}>
              {getSectionNavLabel(section)}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="menu-page__sections">
      {sections.map((section) => (
        <MenuSection
          menuId={menuId}
          sectionId={section.sectionId}
          title={section.title}
          presentation={section.presentation}
          items={section.items}
        />
      ))}
    </div>

    {contactFact?.link && (
      <a
        class="menu-whatsapp-button"
        href={contactFact.link.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Contactar por ${contactFact.link.text}`}
      >
        <svg
          class="menu-whatsapp-button__icon"
          viewBox="0 0 32 32"
          aria-hidden="true"
          focusable="false"
        >
          <path
            fill="currentColor"
            d="M16.02 3.2a12.73 12.73 0 0 0-10.9 19.27L3.6 28.8l6.45-1.49A12.8 12.8 0 1 0 16.02 3.2Zm0 2.32a10.48 10.48 0 0 1 8.86 16.07 10.52 10.52 0 0 1-13.97 3.5l-.39-.23-3.76.87.89-3.64-.25-.4A10.42 10.42 0 0 1 16.02 5.52Zm-4.5 4.98c-.23 0-.59.08-.9.42-.31.34-1.18 1.16-1.18 2.82 0 1.66 1.21 3.27 1.38 3.49.17.23 2.34 3.75 5.78 5.1 2.86 1.13 3.44.9 4.06.85.62-.06 2.01-.82 2.29-1.61.28-.79.28-1.47.2-1.61-.08-.14-.31-.23-.65-.4-.34-.17-2.01-.99-2.32-1.1-.31-.12-.54-.17-.76.17-.23.34-.87 1.1-1.07 1.33-.2.23-.39.25-.73.08-.34-.17-1.42-.52-2.71-1.67-1-.89-1.68-2-1.88-2.34-.2-.34-.02-.52.15-.69.16-.15.34-.39.51-.59.17-.2.23-.34.34-.56.11-.23.06-.42-.03-.59-.08-.17-.76-1.84-1.04-2.51-.27-.65-.55-.56-.76-.57h-.68Z"
          />
        </svg>
      </a>
    )}
  </main>

  <dialog class="photo-sheet" data-photo-sheet aria-labelledby="photo-sheet-title">
    <div class="photo-sheet__panel">
      <div class="photo-sheet__header">
        <h2 class="photo-sheet__title" id="photo-sheet-title" data-photo-title>
          Foto del plato
        </h2>
        <button class="photo-sheet__close" type="button" data-photo-close>
          Cerrar
        </button>
      </div>

      <div class="photo-frame" data-photo-frame></div>
      <div class="photo-sheet__controls" data-photo-controls hidden>
        <button class="photo-sheet__nav" type="button" data-photo-prev>
          Anterior
        </button>
        <span class="photo-sheet__count" data-photo-count></span>
        <button class="photo-sheet__nav" type="button" data-photo-next>
          Siguiente
        </button>
      </div>
    </div>
  </dialog>
  <script is:inline type="module" src="/scripts/menu-index-sticky.js"></script>
  <script is:inline type="module" src="/scripts/menu-photo-sheet.js"></script>
  <script is:inline type="module" src="/scripts/menu-availability-overlay.js"></script>
</BaseLayout>
