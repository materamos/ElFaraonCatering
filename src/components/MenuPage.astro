---
import type { MenuProfileData, MenuSectionData } from "../types/menu";
import BaseLayout from "../layouts/BaseLayout.astro";
import MenuSection from "./MenuSection.astro";

interface Props {
  menuId: string;
  profile: MenuProfileData;
  sections: MenuSectionData[];
}

const { menuId, profile, sections } = Astro.props;
const publicSupabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const publicSupabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const scheduleFact = profile.facts.find((fact) => fact.id === "horario");
const paymentFact = profile.facts.find((fact) => fact.id === "pagos");
const getSectionNavLabel = (section: MenuSectionData) =>
  section.sectionId === "platos-principales" ? "Platos principales" : section.title;
const getPaymentValue = (value: string) =>
  value
    .split(",")
    .map((part) => part.trim())
    .filter(Boolean)
    .map((part) => {
      const normalizedPart = part.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();

      if (normalizedPart === "tarjeta credito") {
        return "Tarjeta de Cr\u00e9dito";
      }

      if (normalizedPart === "tarjeta debito") {
        return "Tarjeta de D\u00e9bito";
      }

      return part;
    })
    .join(" • ");
---

<BaseLayout
  title={`${profile.title} | El Faraón Catering`}
  description={profile.title}
  bodyClass="menu-body"
>
  <main
    class="page-shell menu-page"
    data-menu-id={menuId}
    data-supabase-url={publicSupabaseUrl}
    data-supabase-anon-key={publicSupabaseAnonKey}
  >
    <header class="menu-page__hero">
      <div class="menu-page__hero-top">
        <h1 class="menu-page__hero-label">{profile.title}</h1>
        <p class="menu-page__hero-label">buffet</p>
      </div>

      <div class="menu-page__logo-space">
        <img
          class="menu-page__logo"
          src="/brand/el-faraon-logo.png"
          alt="El Faraon Catering"
        />
      </div>

    </header>

    {scheduleFact && (
      <p class="menu-page__schedule">
        <span class="menu-page__fact-label">LUN A VIE</span>
        <span class="menu-page__fact-value">{scheduleFact.value}</span>
      </p>
    )}

    {paymentFact && (
      <section class="menu-page__payment-card" aria-label="Medios de pago">
        <p class="menu-page__fact-label">MEDIOS DE PAGO</p>
        <p class="menu-page__payment-value">{getPaymentValue(paymentFact.value)}</p>
      </section>
    )}

    <nav class="menu-index" aria-labelledby="menu-index-title">
      <h2 class="menu-index__title" id="menu-index-title">Secciones</h2>
      <ul class="menu-index__list">
        {sections.map((section) => (
          <li class="menu-index__item">
            <a class="menu-index__link" href={`#${section.sectionId}`}>
              {getSectionNavLabel(section)}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="menu-page__sections">
      {sections.map((section) => (
        <MenuSection
          menuId={menuId}
          sectionId={section.sectionId}
          title={section.title}
          presentation={section.presentation}
          items={section.items}
        />
      ))}
    </div>
  </main>

  <dialog class="photo-sheet" data-photo-sheet aria-labelledby="photo-sheet-title">
    <div class="photo-sheet__panel">
      <div class="photo-sheet__header">
        <p class="eyebrow">Imagen</p>
        <button class="photo-sheet__close" type="button" data-photo-close>
          Cerrar
        </button>
      </div>

      <h2 class="photo-sheet__title" id="photo-sheet-title" data-photo-title>
        Foto del plato
      </h2>

      <div class="photo-frame" data-photo-frame></div>
      <div class="photo-sheet__controls" data-photo-controls hidden>
        <button class="photo-sheet__nav" type="button" data-photo-prev>
          Anterior
        </button>
        <span class="photo-sheet__count" data-photo-count></span>
        <button class="photo-sheet__nav" type="button" data-photo-next>
          Siguiente
        </button>
      </div>
    </div>
  </dialog>
  <script is:inline>
    const menuIndex = document.querySelector(".menu-index");

    if (menuIndex) {
      let stuckOffset = menuIndex.offsetTop;
      const updateMenuIndexState = () => {
        menuIndex.classList.toggle("menu-index--stuck", window.scrollY >= stuckOffset);
      };
      const refreshMenuIndexOffset = () => {
        stuckOffset = menuIndex.offsetTop;
        updateMenuIndexState();
      };

      updateMenuIndexState();
      window.addEventListener("scroll", updateMenuIndexState, { passive: true });
      window.addEventListener("resize", refreshMenuIndexOffset);
    }
  </script>
  <script is:inline type="module" src="/scripts/menu-photo-sheet.js"></script>
  <script is:inline type="module" src="/scripts/menu-availability-overlay.js"></script>
</BaseLayout>
