---
interface Props {
  name: string;
  description?: string;
  price?: number;
  available: boolean;
  image?: string;
}

const { name, description, price, available, image } = Astro.props;

const formattedPrice =
  typeof price === "number"
    ? new Intl.NumberFormat("es-AR", {
        style: "currency",
        currency: "ARS",
        maximumFractionDigits: 0,
      }).format(price)
    : null;
---

<article class="surface-card flex h-full flex-col gap-4 p-4">
  <div class="flex items-start justify-between gap-3">
    <div class="space-y-2">
      <h3 class="text-xl text-[var(--color-ink)]">{name}</h3>
      {description && (
        <p class="whitespace-pre-line text-sm leading-6 text-[var(--color-muted)]">
          {description}
        </p>
      )}
    </div>
    <span class="status-pill shrink-0" data-state={available ? "available" : "unavailable"}>
      {available ? "Disponible" : "No disponible"}
    </span>
  </div>
  <div class="mt-auto space-y-3">
    {image && (
      <a
        class="photo-button"
        href={image}
        target="_blank"
        rel="noopener noreferrer"
        aria-haspopup="dialog"
        data-photo-trigger
        data-photo-name={name}
        data-photo-src={image}
      >
        Ver foto
      </a>
    )}

    {formattedPrice && (
      <div class="flex items-center justify-between border-t border-[var(--color-line)] pt-4">
        <span class="text-sm font-medium text-[var(--color-muted)]">Precio</span>
        <strong class="text-lg text-[var(--color-brand-strong)]">{formattedPrice}</strong>
      </div>
    )}
  </div>
</article>
