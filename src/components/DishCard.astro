---
import type { MenuItem, MenuOption, MenuPricing, MenuPricingVariant } from "../types/menu";
import { getSafeMenuImagePath } from "../utils/menuImage";
import { getPricingText, getVariantPricingText } from "../utils/menuPricing";

interface Props {
  name: MenuItem["name"];
  description?: MenuItem["description"];
  note?: MenuItem["note"];
  available: boolean;
  pricing?: MenuPricing;
  inheritedPricing?: MenuPricing;
  options?: MenuOption[];
  image?: MenuItem["image"];
  hideHeading?: boolean;
}

const {
  name,
  description,
  note,
  available,
  pricing,
  inheritedPricing,
  options,
  image,
  hideHeading = false,
} = Astro.props;
const safeImage = getSafeMenuImagePath(image);
const effectivePricing = pricing ?? inheritedPricing;
const pricingLabel = pricing ? "Precio" : "Precio de línea";

const directPricingText =
  effectivePricing && effectivePricing.kind !== "variants"
    ? getPricingText(effectivePricing)
    : null;
---

<article class="surface-card flex h-full flex-col gap-4 p-4">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 space-y-2">
      {!hideHeading && <h3 class="break-words text-xl text-[var(--color-ink)]">{name}</h3>}
      {description && (
        <p class="whitespace-pre-line text-sm leading-6 text-[var(--color-muted)]">
          {description}
        </p>
      )}
      {note && (
        <p class="text-sm leading-6 text-[var(--color-muted)]">
          {note}
        </p>
      )}
    </div>
    <span class="status-pill shrink-0" data-state={available ? "available" : "unavailable"}>
      {available ? "Disponible" : "No disponible"}
    </span>
  </div>

  {options && options.length > 0 && (
    <section class="rounded-2xl border border-[var(--color-line)] bg-[rgba(141,91,32,0.04)] p-3">
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-[var(--color-muted)]">
        Opciones
      </p>
      <ul class="mt-2 grid gap-2 text-sm leading-5 text-[var(--color-ink)]">
        {options.map((option) => (
          <li class="flex items-start justify-between gap-3">
            <span>
              {option.name}
              {option.description && (
                <span class="block text-[var(--color-muted)]">{option.description}</span>
              )}
              {option.note && (
                <span class="block text-[var(--color-muted)]">{option.note}</span>
              )}
            </span>
            {option.available === false && (
              <span class="shrink-0 text-xs font-semibold text-[var(--color-danger)]">
                No disponible
              </span>
            )}
          </li>
        ))}
      </ul>
    </section>
  )}

  <div class="mt-auto space-y-3">
    {safeImage && (
      <a
        class="photo-button"
        href={safeImage}
        target="_blank"
        rel="noopener noreferrer"
        aria-haspopup="dialog"
        data-photo-trigger
        data-photo-name={name}
        data-photo-src={safeImage}
      >
        Ver foto
      </a>
    )}

    {directPricingText && (
      <div class="flex items-center justify-between gap-3 border-t border-[var(--color-line)] pt-4">
        <span class="text-sm font-medium text-[var(--color-muted)]">{pricingLabel}</span>
        <strong class="min-w-0 text-right text-lg text-[var(--color-brand-strong)]">
          {directPricingText}
        </strong>
      </div>
    )}

    {effectivePricing?.kind === "variants" && (
      <section class="border-t border-[var(--color-line)] pt-4">
        <p class="text-sm font-medium text-[var(--color-muted)]">Modalidades</p>
        <ul class="mt-3 grid gap-2">
          {effectivePricing.variants.map((variant: MenuPricingVariant) => (
            <li class="flex items-start justify-between gap-3 text-sm leading-5">
              <span class="text-[var(--color-ink)]">
                {variant.name}
                {variant.available === false && (
                  <span class="block font-semibold text-[var(--color-danger)]">
                    No disponible
                  </span>
                )}
              </span>
              <strong class="shrink-0 text-right text-[var(--color-brand-strong)]">
                {getVariantPricingText(variant)}
              </strong>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</article>
