---
import type { MenuItem, MenuOption, MenuPricing, MenuPricingVariant } from "../types/menu";
import { getMenuPhotoImagePath } from "../utils/menuImage";
import { getPricingText, getVariantPricingText } from "../utils/menuPricing";

interface Props {
  menuId: string;
  sectionId: string;
  groupId?: string;
  itemId: string;
  name: MenuItem["name"];
  description?: MenuItem["description"];
  note?: MenuItem["note"];
  available: boolean;
  pricing?: MenuPricing;
  inheritedPricing?: MenuPricing;
  options?: MenuOption[];
  image?: MenuItem["image"];
  hideHeading?: boolean;
}

const {
  menuId,
  sectionId,
  groupId,
  itemId,
  name,
  description,
  note,
  available,
  pricing,
  inheritedPricing,
  options,
  image,
  hideHeading = false,
} = Astro.props;
const photoImage = getMenuPhotoImagePath(image);
const effectivePricing = pricing ?? inheritedPricing;
const pricingLabel = "Precio";
const variants = effectivePricing?.kind === "variants" ? effectivePricing.variants : [];
const hasOperationalVariants = variants.some((variant) => variant.availabilityItemId);

const directPricingText =
  effectivePricing && effectivePricing.kind !== "variants"
    ? getPricingText(effectivePricing)
    : null;
---

<article
  class="dish-row"
  data-menu-id={hasOperationalVariants ? undefined : menuId}
  data-section-id={hasOperationalVariants ? undefined : sectionId}
  data-group-id={hasOperationalVariants ? undefined : groupId}
  data-item-id={hasOperationalVariants ? undefined : itemId}
  data-available={hasOperationalVariants ? undefined : available ? "true" : "false"}
>
  <div class="dish-card__header">
    <div class="dish-card__main">
      {!hideHeading && <h3 class="dish-card__title">{name}</h3>}
      {description && (
        <p class="dish-card__description">
          {description}
        </p>
      )}
      {note && (
        <p class="dish-card__note">
          {note}
        </p>
      )}
    </div>
    {!hasOperationalVariants && (
      <span
        class="status-pill"
        data-availability-status
        data-state={available ? "available" : "unavailable"}
      >
        {available ? "Disponible" : "No disponible"}
      </span>
    )}
  </div>

  {options && options.length > 0 && (
    <section class="dish-card__options">
      <p class="dish-card__option-label">
        Opciones
      </p>
      <ul class="dish-card__option-list">
        {options.map((option) => (
          <li class="dish-card__option">
            <span>
              {option.name}
              {option.description && (
                <span class="dish-card__option-detail">{option.description}</span>
              )}
              {option.note && (
                <span class="dish-card__option-detail">{option.note}</span>
              )}
            </span>
            {option.available === false && (
              <span class="dish-card__option-status">
                No disponible
              </span>
            )}
          </li>
        ))}
      </ul>
    </section>
  )}

  <div class="dish-card__footer">
    {photoImage && (
      <a
        class="photo-button"
        href={photoImage}
        target="_blank"
        rel="noopener noreferrer"
        aria-haspopup="dialog"
        data-photo-trigger
        data-photo-name={name}
        data-photo-src={photoImage}
      >
        Ver foto
      </a>
    )}

    {directPricingText && (
      <div class="dish-card__price-row">
        <span class="dish-card__price-label">{pricingLabel}</span>
        <strong class="dish-card__price">
          {directPricingText}
        </strong>
      </div>
    )}

    {effectivePricing?.kind === "variants" && (
      <section class="dish-card__variants">
        <p class="dish-card__variant-label">Modalidades</p>
        <ul class="dish-card__variant-list">
          {variants.map((variant: MenuPricingVariant) => (
            <li
              class="dish-card__variant"
              data-menu-id={variant.availabilityItemId ? menuId : undefined}
              data-section-id={variant.availabilityItemId ? sectionId : undefined}
              data-group-id={variant.availabilityItemId ? "" : undefined}
              data-item-id={variant.availabilityItemId}
              data-available={
                variant.availabilityItemId
                  ? variant.available ? "true" : "false"
                  : undefined
              }
            >
              <span>
                {variant.name}
                {variant.availabilityItemId ? (
                  <span
                    class="dish-card__variant-status"
                    data-availability-status
                    data-state={variant.available ? "available" : "unavailable"}
                  >
                    {variant.available ? "Disponible" : "No disponible"}
                  </span>
                ) : variant.available === false && (
                  <span class="dish-card__variant-status">
                    No disponible
                  </span>
                )}
              </span>
              <strong class="dish-card__variant-price">
                {getVariantPricingText(variant)}
              </strong>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</article>
