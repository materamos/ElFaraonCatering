---
import type { MenuItem, MenuOption, MenuPricing, MenuPricingVariant } from "../types/menu";
import { getSafeMenuImagePath } from "../utils/menuImage";
import { getPricingText, getVariantPricingText } from "../utils/menuPricing";

interface Props {
  menuId: string;
  sectionId: string;
  itemId: string;
  name: MenuItem["name"];
  description?: MenuItem["description"];
  available: boolean;
  pricing?: MenuPricing;
  options?: MenuOption[];
  images?: MenuItem["images"];
}

const {
  menuId,
  sectionId,
  itemId,
  name,
  description,
  available,
  pricing,
  options,
  images,
} = Astro.props;
const displayImages = [
  ...new Set(
    (images ?? [])
      .map((imagePath) => getSafeMenuImagePath(imagePath))
      .filter((imagePath): imagePath is string => Boolean(imagePath)),
  ),
];
const displayImage = displayImages[0];
const photoButtonLabel = displayImages.length > 1 ? "Ver fotos" : "Ver foto";
const effectivePricing = pricing;
const hasVariantPricing = effectivePricing?.kind === "variants";
const variants = effectivePricing?.kind === "variants" ? effectivePricing.variants : [];
const hasOperationalVariants = variants.some((variant) => variant.availabilityItemId);
const displayOptions = options ?? [];
const hasOptions = displayOptions.length > 0;
const getOptionAvailabilityItemId = (option: MenuOption) => `${itemId}-${option.id}`;

const directPricingText =
  effectivePricing && effectivePricing.kind !== "variants"
    ? getPricingText(effectivePricing)
    : null;
const hasFooterContent = Boolean(
  displayImage ||
    hasVariantPricing,
);
---

<article
  class="dish-row"
  data-menu-id={hasOperationalVariants ? undefined : menuId}
  data-section-id={hasOperationalVariants ? undefined : sectionId}
  data-item-id={hasOperationalVariants ? undefined : itemId}
  data-available={hasOperationalVariants ? undefined : available ? "true" : "false"}
>
  <div class="dish-card__header">
    <div class="dish-card__main">
      <h3 class="dish-card__title">{name}</h3>
      {description && (
        <p class="dish-card__description">
          {description}
        </p>
      )}
    </div>
    {((!hasOperationalVariants && !available) || directPricingText) && (
      <div class="dish-card__header-meta">
        {!hasOperationalVariants && !available && (
          <span
            class="status-pill"
            data-availability-status
            data-state="unavailable"
          >
            No disponible
          </span>
        )}
        {directPricingText && (
          <strong class="dish-card__price">
            {directPricingText}
          </strong>
        )}
      </div>
    )}
  </div>

  {hasOptions && (
    <section class="dish-card__options">
      <p class="dish-card__option-label">
        Opciones
      </p>
      <ul class="dish-card__option-list">
        {displayOptions.map((option) => (
          <li
            class="dish-card__option"
            data-menu-id={menuId}
            data-section-id={sectionId}
            data-item-id={getOptionAvailabilityItemId(option)}
            data-available={option.available ? "true" : "false"}
          >
            <span>{option.name}</span>
            {option.available === false && (
              <span class="dish-card__option-status">
                No disponible
              </span>
            )}
          </li>
        ))}
      </ul>
    </section>
  )}

  {hasFooterContent && (
    <div class="dish-card__footer">
      {displayImage && !hasVariantPricing && (
        <div class="dish-card__price-row dish-card__price-row--with-image">
          <a
            class="photo-button"
            href={displayImage}
            target="_blank"
            rel="noopener noreferrer"
            aria-haspopup="dialog"
            data-photo-trigger
            data-photo-name={name}
            data-photo-src={displayImage}
            data-photo-srcs={JSON.stringify(displayImages)}
            data-photo-alt={`Foto de ${name}`}
          >
            {photoButtonLabel}
          </a>
        </div>
      )}

      {hasVariantPricing && (
        <section class="dish-card__variants">
          <p class="dish-card__variant-label">Modalidades</p>
          <ul class="dish-card__variant-list">
            {variants.map((variant: MenuPricingVariant) => (
              <li
                class="dish-card__variant"
                data-menu-id={variant.availabilityItemId ? menuId : undefined}
                data-section-id={variant.availabilityItemId ? sectionId : undefined}
                data-item-id={variant.availabilityItemId}
                data-available={
                  variant.availabilityItemId
                    ? variant.available ? "true" : "false"
                    : undefined
                }
              >
                <span>
                  {variant.name}
                  {variant.availabilityItemId ? (
                    !variant.available && (
                      <span
                        class="dish-card__variant-status"
                        data-availability-status
                        data-state="unavailable"
                      >
                        No disponible
                      </span>
                    )
                  ) : variant.available === false && (
                    <span class="dish-card__variant-status">
                      No disponible
                    </span>
                  )}
                </span>
                <strong class="dish-card__variant-price">
                  {getVariantPricingText(variant)}
                </strong>
              </li>
            ))}
          </ul>
        </section>
      )}

      {displayImage && hasVariantPricing && (
        <a
          class="photo-button"
          href={displayImage}
          target="_blank"
          rel="noopener noreferrer"
          aria-haspopup="dialog"
          data-photo-trigger
          data-photo-name={name}
          data-photo-src={displayImage}
          data-photo-srcs={JSON.stringify(displayImages)}
          data-photo-alt={`Foto de ${name}`}
        >
          {photoButtonLabel}
        </a>
      )}
    </div>
  )}
</article>
