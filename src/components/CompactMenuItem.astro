---
import type { MenuItem, MenuPricing, MenuPricingVariant } from "../types/menu";
import { getPricingText, getVariantPricingText } from "../utils/menuPricing";

interface Props {
  menuId: string;
  sectionId: string;
  groupId?: string;
  item: MenuItem;
}

const { menuId, sectionId, groupId, item } = Astro.props;
const getDirectPricingText = (pricing?: MenuPricing) =>
  pricing && pricing.kind !== "variants" ? getPricingText(pricing) : null;
const directPricingText = getDirectPricingText(item.pricing);
const variants = item.pricing?.kind === "variants" ? item.pricing.variants : [];
const hasOperationalVariants = variants.some((variant) => variant.availabilityItemId);
---

<li
  class="compact-item"
  data-menu-id={hasOperationalVariants ? undefined : menuId}
  data-section-id={hasOperationalVariants ? undefined : sectionId}
  data-group-id={hasOperationalVariants ? undefined : groupId}
  data-item-id={hasOperationalVariants ? undefined : item.itemId}
  data-available={hasOperationalVariants ? undefined : item.available ? "true" : "false"}
>
  <div class="compact-item__content">
    <div class="compact-item__header">
      <h3 class="compact-item__title">
        {item.name}
      </h3>
      {!hasOperationalVariants && !item.available && (
        <span
          class="compact-availability-status"
          data-availability-status
          data-state="unavailable"
        >
          No disponible
        </span>
      )}
    </div>

    {item.description && (
      <p class="compact-item__description">
        {item.description}
      </p>
    )}
    {variants.length > 0 && (
      <ul class="compact-item__variants">
        {variants.map((variant: MenuPricingVariant) => (
          <li
            class="compact-item__variant"
            data-menu-id={variant.availabilityItemId ? menuId : undefined}
            data-section-id={variant.availabilityItemId ? sectionId : undefined}
            data-group-id={variant.availabilityItemId ? "" : undefined}
            data-item-id={variant.availabilityItemId}
            data-available={
              variant.availabilityItemId
                ? variant.available ? "true" : "false"
                : undefined
            }
          >
            <span>
              {variant.name}
              {variant.availabilityItemId ? (
                !variant.available && (
                  <span
                    class="dish-card__variant-status"
                    data-availability-status
                    data-state="unavailable"
                  >
                    No disponible
                  </span>
                )
              ) : variant.available === false && (
                <span class="dish-card__variant-status">
                  No disponible
                </span>
              )}
            </span>
            <strong class="compact-item__variant-price">
              {getVariantPricingText(variant)}
            </strong>
          </li>
        ))}
      </ul>
    )}
  </div>

  {directPricingText && (
    <strong class="compact-item__price">
      {directPricingText}
    </strong>
  )}
</li>
