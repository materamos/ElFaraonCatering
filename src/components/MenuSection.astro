---
import type {
  MenuGroup,
  MenuItem,
  MenuSectionPresentation,
} from "../types/menu";
import CompactMenuItem from "./CompactMenuItem.astro";
import DishCard from "./DishCard.astro";

interface Props {
  menuId: string;
  sectionId: string;
  title: string;
  description?: string;
  note?: string;
  items?: MenuItem[];
  groups?: MenuGroup[];
  presentation?: MenuSectionPresentation;
}

const {
  menuId,
  sectionId,
  title,
  description,
  note,
  items,
  groups,
  presentation = "cards",
} = Astro.props;
const normalizeHeadingText = (value: string) => value.trim().toLowerCase();
const hasSingleItemMatchingSection =
  items?.length === 1 &&
  normalizeHeadingText(items[0].name) === normalizeHeadingText(title) &&
  Boolean(items[0].description || items[0].note || items[0].options?.length || items[0].image);
---

<section class="menu-section">
  <div class="menu-section__header">
    <h2 class="menu-section__title">{title}</h2>
    {description && (
      <p class="menu-section__description">{description}</p>
    )}
    {note && (
      <p class="menu-section__note">
        {note}
      </p>
    )}
  </div>

  {items && presentation === "compact-list" && (
    <section class="menu-section__compact">
      <ul class="compact-list">
        {items.map((item) => (
          <CompactMenuItem
            menuId={menuId}
            sectionId={sectionId}
            item={item}
          />
        ))}
      </ul>
    </section>
  )}

  {items && presentation !== "compact-list" && (
    <div class="menu-section__items">
      {items.map((item) => (
        <DishCard
          menuId={menuId}
          sectionId={sectionId}
          itemId={item.itemId}
          name={item.name}
          description={item.description}
          note={item.note}
          available={item.available}
          pricing={item.pricing}
          options={item.options}
          image={item.image}
          hideHeading={hasSingleItemMatchingSection}
        />
      ))}
    </div>
  )}

  {groups && (
    <div class="menu-section__groups">
      {groups.map((group) => {
        const itemGroupId =
          group.availabilityGroupId === undefined
            ? group.groupId
            : group.availabilityGroupId;

        return (
          <section class="menu-group">
            <div class="menu-group__header">
              <h3 class="menu-group__title">{group.title}</h3>
              {group.description && (
                <p class="menu-group__description">{group.description}</p>
              )}
              {group.note && (
                <p class="menu-group__note">
                  {group.note}
                </p>
              )}
            </div>

            {presentation === "compact-list" ? (
              <ul class="compact-list">
                {group.items.map((item: MenuItem) => (
                  <CompactMenuItem
                    menuId={menuId}
                    sectionId={sectionId}
                    groupId={itemGroupId}
                    item={item}
                  />
                ))}
              </ul>
            ) : (
              <div class="menu-group__items">
                {group.items.map((item: MenuItem) => (
                  <DishCard
                    menuId={menuId}
                    sectionId={sectionId}
                    groupId={itemGroupId}
                    itemId={item.itemId}
                    name={item.name}
                    description={item.description}
                    note={item.note}
                    available={item.available}
                    pricing={item.pricing}
                    inheritedPricing={group.pricing}
                    options={item.options}
                    image={item.image}
                  />
                ))}
              </div>
            )}
          </section>
        );
      })}
    </div>
  )}
</section>
