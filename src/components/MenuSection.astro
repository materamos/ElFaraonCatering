---
import type { MenuGroup, MenuItem } from "../types/menu";
import { getPricingSummary } from "../utils/menuPricing";
import DishCard from "./DishCard.astro";

interface Props {
  title: string;
  description?: string;
  note?: string;
  items?: MenuItem[];
  groups?: MenuGroup[];
}

const { title, description, note, items, groups } = Astro.props;
const normalizeHeadingText = (value: string) => value.trim().toLowerCase();
const hasSingleItemMatchingSection =
  items?.length === 1 && normalizeHeadingText(items[0].name) === normalizeHeadingText(title);
---

<section class="space-y-4">
  <div class="space-y-2">
    <h2 class="text-3xl text-[var(--color-ink)]">{title}</h2>
    {description && (
      <p class="max-w-2xl text-sm leading-6 text-[var(--color-muted)]">{description}</p>
    )}
    {note && (
      <p class="max-w-2xl text-sm font-semibold leading-6 text-[var(--color-brand-strong)]">
        {note}
      </p>
    )}
  </div>

  {items && (
    <div class="grid gap-4">
      {items.map((item) => (
        <DishCard
          name={item.name}
          description={item.description}
          note={item.note}
          available={item.available}
          pricing={item.pricing}
          options={item.options}
          image={item.image}
          hideHeading={hasSingleItemMatchingSection}
        />
      ))}
    </div>
  )}

  {groups && (
    <div class="space-y-5">
      {groups.map((group) => (
        <section class="space-y-3 rounded-[var(--radius-panel)] border border-[var(--color-line)] bg-[rgba(255,253,249,0.52)] p-3 sm:p-4">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="space-y-1">
              <h3 class="text-2xl text-[var(--color-ink)]">{group.title}</h3>
              {group.description && (
                <p class="text-sm leading-6 text-[var(--color-muted)]">{group.description}</p>
              )}
              {group.note && (
                <p class="text-sm font-semibold leading-6 text-[var(--color-brand-strong)]">
                  {group.note}
                </p>
              )}
            </div>
            {getPricingSummary(group.pricing) && (
              <span class="rounded-full border border-[var(--color-line)] bg-[var(--color-surface)] px-3 py-1 text-sm font-bold text-[var(--color-brand-strong)]">
                {getPricingSummary(group.pricing)}
              </span>
            )}
          </div>

          <div class="grid gap-3">
            {group.items.map((item: MenuItem) => (
              <DishCard
                name={item.name}
                description={item.description}
                note={item.note}
                available={item.available}
                pricing={item.pricing}
                inheritedPricing={group.pricing}
                options={item.options}
                image={item.image}
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  )}
</section>
