---
import type { MenuItem, MenuSectionPresentation } from "../types/menu";
import CompactMenuItem from "./CompactMenuItem.astro";
import DishCard from "./DishCard.astro";

interface Props {
  menuId: string;
  sectionId: string;
  title: string;
  description?: string;
  items: MenuItem[];
  presentation?: MenuSectionPresentation;
}

const {
  menuId,
  sectionId,
  title,
  description,
  items,
  presentation = "cards",
} = Astro.props;
---

<section class="menu-section" id={sectionId}>
  <div class="menu-section__header">
    <h2 class="menu-section__title">{title}</h2>
    {description && (
      <p class="menu-section__description">{description}</p>
    )}
  </div>

  {presentation === "compact-list" && (
    <section class="menu-section__compact">
      <ul class="compact-list">
        {items.map((item) => (
          <CompactMenuItem
            menuId={menuId}
            sectionId={sectionId}
            item={item}
          />
        ))}
      </ul>
    </section>
  )}

  {presentation !== "compact-list" && (
    <div class="menu-section__items">
      {items.map((item) => (
        <DishCard
          menuId={menuId}
          sectionId={sectionId}
          itemId={item.itemId}
          name={item.name}
          description={item.description}
          available={item.available}
          pricing={item.pricing}
          options={item.options}
          image={item.image}
          images={item.images}
        />
      ))}
    </div>
  )}

</section>
