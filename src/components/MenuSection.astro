---
import type {
  MenuGroup,
  MenuItem,
  MenuPricing,
  MenuPricingVariant,
  MenuSectionPresentation,
} from "../types/menu";
import DishCard from "./DishCard.astro";
import { getPricingText, getVariantPricingText } from "../utils/menuPricing";

interface Props {
  menuId: string;
  sectionId: string;
  title: string;
  description?: string;
  note?: string;
  items?: MenuItem[];
  groups?: MenuGroup[];
  presentation?: MenuSectionPresentation;
}

const {
  menuId,
  sectionId,
  title,
  description,
  note,
  items,
  groups,
  presentation = "cards",
} = Astro.props;
const normalizeHeadingText = (value: string) => value.trim().toLowerCase();
const hasSingleItemMatchingSection =
  items?.length === 1 &&
  normalizeHeadingText(items[0].name) === normalizeHeadingText(title) &&
  Boolean(items[0].description || items[0].note || items[0].options?.length || items[0].image);
const getDirectPricingText = (pricing?: MenuPricing) =>
  pricing && pricing.kind !== "variants" ? getPricingText(pricing) : null;
---

<section class="space-y-4">
  <div class="space-y-2">
    <h2 class="text-3xl text-[var(--color-ink)]">{title}</h2>
    {description && (
      <p class="max-w-2xl text-sm leading-6 text-[var(--color-muted)]">{description}</p>
    )}
    {note && (
      <p class="max-w-2xl text-sm font-semibold leading-6 text-[var(--color-brand-strong)]">
        {note}
      </p>
    )}
  </div>

  {items && presentation === "compact-list" && (
    <section class="surface-card p-3 sm:p-4">
      <ul class="divide-y divide-[var(--color-line)]">
        {items.map((item) => {
          const directPricingText = getDirectPricingText(item.pricing);
          const variants = item.pricing?.kind === "variants" ? item.pricing.variants : [];

          return (
            <li
              class="grid grid-cols-[minmax(0,1fr)_auto] gap-3 py-3 first:pt-0 last:pb-0"
              data-menu-id={menuId}
              data-section-id={sectionId}
              data-item-id={item.itemId}
              data-available={item.available ? "true" : "false"}
            >
              <div class="min-w-0 space-y-1">
                <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                  <h3 class="break-words text-base font-semibold leading-6 text-[var(--color-ink)]">
                    {item.name}
                  </h3>
                  <span
                    class="compact-availability-status"
                    data-availability-status
                    data-state={item.available ? "available" : "unavailable"}
                  >
                    {item.available ? "Disponible" : "No disponible"}
                  </span>
                </div>

                {item.description && (
                  <p class="whitespace-pre-line text-sm leading-6 text-[var(--color-muted)]">
                    {item.description}
                  </p>
                )}
                {item.note && (
                  <p class="text-sm leading-6 text-[var(--color-muted)]">{item.note}</p>
                )}

                {variants.length > 0 && (
                  <ul class="mt-2 grid gap-1 text-sm leading-5">
                    {variants.map((variant: MenuPricingVariant) => (
                      <li class="flex items-start justify-between gap-3">
                        <span class="text-[var(--color-ink)]">
                          {variant.name}
                          {variant.available === false && (
                            <span class="block font-semibold text-[var(--color-danger)]">
                              No disponible
                            </span>
                          )}
                        </span>
                        <strong class="shrink-0 text-right text-[var(--color-brand-strong)]">
                          {getVariantPricingText(variant)}
                        </strong>
                      </li>
                    ))}
                  </ul>
                )}
              </div>

              {directPricingText && (
                <strong class="shrink-0 text-right text-base font-semibold leading-6 text-[var(--color-brand-strong)]">
                  {directPricingText}
                </strong>
              )}
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {items && presentation !== "compact-list" && (
    <div class="grid gap-4">
      {items.map((item) => (
        <DishCard
          menuId={menuId}
          sectionId={sectionId}
          itemId={item.itemId}
          name={item.name}
          description={item.description}
          note={item.note}
          available={item.available}
          pricing={item.pricing}
          options={item.options}
          image={item.image}
          hideHeading={hasSingleItemMatchingSection}
        />
      ))}
    </div>
  )}

  {groups && (
    <div class="space-y-5">
      {groups.map((group) => (
        <section class="space-y-3 rounded-[var(--radius-panel)] border border-[var(--color-line)] bg-[rgba(255,253,249,0.52)] p-3 sm:p-4">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="space-y-1">
              <h3 class="text-2xl text-[var(--color-ink)]">{group.title}</h3>
              {group.description && (
                <p class="text-sm leading-6 text-[var(--color-muted)]">{group.description}</p>
              )}
              {group.note && (
                <p class="text-sm font-semibold leading-6 text-[var(--color-brand-strong)]">
                  {group.note}
                </p>
              )}
            </div>
          </div>

          <div class="grid gap-3">
            {group.items.map((item: MenuItem) => (
              <DishCard
                menuId={menuId}
                sectionId={sectionId}
                groupId={group.groupId}
                itemId={item.itemId}
                name={item.name}
                description={item.description}
                note={item.note}
                available={item.available}
                pricing={item.pricing}
                inheritedPricing={group.pricing}
                options={item.options}
                image={item.image}
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  )}
</section>
