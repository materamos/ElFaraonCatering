---
interface MenuInfoFact {
  label: string;
  value: string;
}

interface MenuInfoPayment {
  label: string;
  methods: string[];
}

interface Props {
  title: string;
  facts: MenuInfoFact[];
  payment: MenuInfoPayment;
}

const { title, facts, payment } = Astro.props;
---

<aside class="menu-info-panel">
  <p class="eyebrow">{title}</p>
  <dl class="menu-info-panel__facts">
    {facts.map((fact) => (
      <div class="menu-info-panel__fact">
        <dt class="menu-info-panel__label">{fact.label}</dt>
        <dd class="menu-info-panel__value">{fact.value}</dd>
      </div>
    ))}
  </dl>

  <section class="menu-info-panel__payment" aria-labelledby="menu-payment-title">
    <h2 class="menu-info-panel__label menu-info-panel__label--strong" id="menu-payment-title">
      {payment.label}
    </h2>

    <div class="menu-info-panel__chips" role="list" aria-label={payment.label}>
      {payment.methods.map((method) => (
        <span class="menu-info-chip" role="listitem">
          {method}
        </span>
      ))}
    </div>
  </section>
</aside>
