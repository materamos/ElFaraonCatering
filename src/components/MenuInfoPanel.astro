---
interface MenuInfoFact {
  label: string;
  value: string;
  link?: {
    text: string;
    href: string;
  };
}

interface Props {
  title: string;
  facts: MenuInfoFact[];
}

const { title, facts } = Astro.props;
---

<aside class="menu-info-panel">
  <p class="eyebrow">{title}</p>
  <dl class="menu-info-panel__facts">
    {facts.map((fact) => (
      <div class="menu-info-panel__fact">
        <dt class="menu-info-panel__label">{fact.label}</dt>
        <dd class="menu-info-panel__value">
          {fact.value}
          {fact.link && (
            <>
              {" "}
              <a
                class="menu-info-panel__link"
                href={fact.link.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                {fact.link.text}
              </a>
            </>
          )}
        </dd>
      </div>
    ))}
  </dl>
</aside>
