PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_DB_URL=
SUPABASE_AUDIT_DB_URL=

# Optional local-only Supabase Management API token for CLI audits such as
# `npm run supabase -- secrets list`. Do not expose it as PUBLIC_* and do not
# set it in frontend hosting envs.
# SUPABASE_ACCESS_TOKEN=

# Supabase Edge Function secrets for publish-menu-changes.
# Set real values with `supabase secrets set`; do not expose them as PUBLIC_*.
VERCEL_DEPLOY_HOOK_URL=
PUBLISH_ALLOWED_ORIGINS=
PUBLISH_COOLDOWN_SECONDS=60
